<!-- 手风琴卡片 -->
<view class="accordion-card {{completed ? 'is-completed' : ''}}">
  <!-- 头部：序号 + 标题 + 已选/请选择 + 箭头 -->
  <view class="card-header" bindtap="onToggle">
    <view class="header-left">
      <image class="num-icon" src="/assets/icons/num-{{number}}.svg" mode="aspectFit" />
      <text class="header-title">{{title}}</text>
    </view>
    <view class="header-right">
      <text wx:if="{{completed}}" class="selected-label">{{selectedLabel}}</text>
      <text wx:elif="{{!expanded}}" class="placeholder-label">请选择</text>
      <image class="chevron {{expanded ? 'chevron-up' : ''}}" src="/assets/icons/chevron-down.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- 展开内容 -->
  <view wx:if="{{expanded}}" class="card-body">
    <slot></slot>
  </view>
</view>
