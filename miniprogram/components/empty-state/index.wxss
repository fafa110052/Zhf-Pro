/**
 * 空状态组件样式
 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.7;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.6;
  margin-top: 8rpx;
}

.empty-action {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  font-size: 26rpx;
  color: var(--color-accent);
  background: var(--color-accent-light);
  border: none;
  border-radius: 40rpx;
  line-height: 1.4;
}

.empty-action:active {
  background: var(--color-accent-light);
}
