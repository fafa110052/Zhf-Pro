<view class="banner-wrap" style="height:{{height}}rpx;">
  <swiper style="height:{{height}}rpx;"
    autoplay="{{autoplay}}"
    interval="{{interval}}"
    circular="{{banners.length > 1}}"
    bindchange="onSwiperChange">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image class="banner-img" src="{{item.image}}" mode="aspectFill"
        data-index="{{index}}" bindtap="onBannerTap"/>
      <view wx:if="{{item.title}}" class="banner-title">{{item.title}}</view>
    </swiper-item>
  </swiper>
  <!-- 自定义分页器（图片下方） -->
  <view wx:if="{{banners.length > 1}}" class="banner-dots">
    <view
      wx:for="{{banners}}"
      wx:key="id"
      class="banner-dot {{index === currentSwiperIndex ? 'banner-dot-active' : ''}}"
    ></view>
  </view>
</view>
