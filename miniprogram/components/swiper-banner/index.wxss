.banner-wrap{width:100%;overflow:hidden;border-radius:20rpx;position:relative}
.banner-img{width:100%;height:100%}
.banner-title{position:absolute;bottom:0;left:0;right:0;padding:20rpx 24rpx;background:linear-gradient(transparent,rgba(0,0,0,0.55));color:#fff;font-size:28rpx}
.banner-slogan-overlay{position:absolute;bottom:0;left:0;right:0;padding:60rpx 32rpx 32rpx;background:linear-gradient(to bottom,transparent 0%,rgba(0,0,0,0.55) 100%);display:flex;flex-direction:column;align-items:center;justify-content:flex-end;pointer-events:none}
.banner-slogan-text{color:#fff;font-size:40rpx;font-weight:700;text-shadow:0 2rpx 8rpx rgba(0,0,0,0.3);text-align:center}
.banner-slogan-sub{color:rgba(255,255,255,0.85);font-size:24rpx;margin-top:8rpx;text-shadow:0 1rpx 4rpx rgba(0,0,0,0.3)}
