/**
 * 步骤进度条组件样式 — 紧凑横条，适合吸附在导航栏下方
 */
.progress-steps {
  display: flex;
  align-items: flex-start;
  width: 100%;
  height: 110rpx;
  padding: 16rpx 12rpx 0;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.95);
}

.step-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

/* ─── 圆点 + 连线 ─── */
.dot-row {
  display: flex;
  align-items: center;
  width: 100%;
}

.step-dot {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.line {
  flex: 1;
  height: 2rpx;
  background: #E5E7EB;
}

.line-done {
  background: #C9A96E;
}

.line-hidden {
  background: transparent;
}

/* ─── 标签 ─── */
.step-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #9CA3AF;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.label-active {
  color: #C9A96E;
}
