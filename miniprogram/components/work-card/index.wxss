/**
 * 作品卡片组件样式
 */
.work-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease;
}

.work-card:active {
  transform: scale(0.97);
}

/* ─── 封面 ─── */
.card-cover {
  position: relative;
  width: 100%;
  background: #f1f5f9;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  display: block;
}

.cover-placeholder {
  width: 100%;
  padding-top: 75%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
}

.placeholder-icon {
  font-size: 56rpx;
}

/* 风格标签 */
.style-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 4rpx 14rpx;
  background: rgba(30, 41, 59, 0.75);
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #fff;
  backdrop-filter: blur(8rpx);
}

/* ─── 信息 ─── */
.card-body {
  padding: 16rpx 20rpx 20rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #0f172a;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ─── Meta ─── */
.card-meta {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  gap: 6rpx;
}

.meta-text {
  font-size: 22rpx;
  color: #94a3b8;
}

.meta-dot {
  font-size: 22rpx;
  color: #cbd5e1;
}

.meta-views {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-left: auto;
  font-size: 20rpx;
  color: #94a3b8;
}

.views-icon {
  font-size: 18rpx;
}

.views-num {
  font-size: 20rpx;
}
