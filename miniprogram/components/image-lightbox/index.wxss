/**
 * 图片放大 lightbox 组件样式
 */
.lightbox-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  flex-direction: column;
}

/* ─── 顶部栏 ─── */
.lb-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
}

.lb-counter {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

.lb-close-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.lb-close {
  width: 28rpx;
  height: 28rpx;
}

/* ─── 图片轮播 ─── */
.lb-swiper {
  flex: 1;
  width: 100%;
}

.lb-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* ─── 底部栏 ─── */
.lb-bottombar {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 标题/型号/规格信息块 */
.lb-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 20rpx;
}

.lb-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.lb-line {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.lb-btn {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #C9A96E, #B8944E);
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.lb-btn:active {
  opacity: 0.85;
}

/* 已选中态：浅底金字，禁用观感 */
.lb-btn-selected {
  background: rgba(255, 255, 255, 0.95);
  border: 2rpx solid #C9A96E;
  box-sizing: border-box;
  color: #C9A96E;
}

.lb-check {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}
