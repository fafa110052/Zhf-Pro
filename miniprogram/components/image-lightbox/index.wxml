<!-- 图片放大预览 -->
<view wx:if="{{visible}}" class="lightbox-mask" catchtap="onClose" catchtouchmove="noop">
  <!-- 顶部：名称 + 计数 + 关闭 -->
  <view class="lb-topbar" catchtap="noop">
    <text class="lb-name">{{images[current].name}}</text>
    <text class="lb-counter">{{current + 1}}/{{images.length}}</text>
    <view class="lb-close-wrap" catchtap="onClose">
      <image class="lb-close" src="/assets/icons/close.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- 图片轮播（点击图片区域冒泡到遮罩 → 关闭） -->
  <swiper class="lb-swiper" current="{{current}}" bindchange="onSwiperChange">
    <swiper-item wx:for="{{images}}" wx:key="id">
      <image class="lb-image" src="{{item.url}}" mode="aspectFit" />
    </swiper-item>
  </swiper>

  <!-- 底部：选中按钮 -->
  <view class="lb-bottombar" catchtap="noop">
    <view wx:if="{{selectedId !== null && images[current].id === selectedId}}" class="lb-btn lb-btn-selected">
      <image class="lb-check" src="/assets/icons/check.svg" mode="aspectFit" />
      <text>已选中</text>
    </view>
    <view wx:else class="lb-btn" catchtap="onSelect">选中此项</view>
  </view>
</view>
