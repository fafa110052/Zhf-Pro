/**
 * 住好房装修展示平台 — 全局样式
 *
 * 设计系统  V2.0 温暖精致风：
 *   - 主色 香槟金 #c8a96e          链接/强调/选中态
 *   - 辅色 暖棕 #3d3226            标题/重点文字
 *   - 背景 暖米白 #faf8f5          页面底色
 *   - 卡片 暖白 #fffdf9            内容容器
 *   - 文字 暖灰体系                  层级递进
 */

/* ═══ 基础重置 ═══ */
page {
  --color-primary: #3d3226;
  --color-accent: #c8a96e;
  --color-accent-deep: #a8895a;
  --color-accent-light: #faf5ed;
  --color-success: #10b981;
  --color-warning: #f59e0b;
  --color-danger: #ef4444;
  --color-info: #6366f1;

  --text-primary: #3d3226;
  --text-secondary: #7a6e5e;
  --text-tertiary: #b8a99a;
  --text-placeholder: #cbc0b0;

  --bg-page: #faf8f5;
  --bg-card: #fffdf9;
  --bg-mask: rgba(0, 0, 0, 0.5);

  --border-color: #e8e0d5;
  --border-radius: 12rpx;
  --border-radius-sm: 8rpx;
  --border-radius-lg: 16rpx;
  --border-radius-xl: 20rpx;

  --shadow-sm: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);

  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-base: 28rpx;
  --font-md: 30rpx;
  --font-lg: 34rpx;
  --font-xl: 40rpx;
  --font-2xl: 48rpx;

  --gradient-warm: linear-gradient(135deg, #c8a96e, #b8956a);
  --gradient-banner-mask: linear-gradient(to bottom, transparent 30%, rgba(0,0,0,0.55) 100%);

  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-base);
  color: var(--text-primary);
  background-color: var(--bg-page);
  line-height: 1.6;
}

/* ═══ 通用工具类 ═══ */

/* Flex 布局 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-end { justify-content: flex-end; }

/* 间距 */
.m-0 { margin: 0; }
.mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-12 { margin-bottom: 12rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-8 { margin-left: 8rpx; }
.mr-8 { margin-right: 8rpx; }
.mr-12 { margin-right: 12rpx; }

.p-16 { padding: 16rpx; }
.p-20 { padding: 20rpx; }
.p-24 { padding: 24rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }
.py-12 { padding-top: 12rpx; padding-bottom: 12rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }

/* 文字 */
.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-base { font-size: var(--font-base); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-accent { color: var(--color-accent); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-white { color: #ffffff; }

.font-bold { font-weight: 700; }
.font-medium { font-weight: 500; }
.text-center { text-align: center; }
.text-right { text-align: right; }

/* 行截断 */
.line-1 {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.line-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--border-radius);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  font-weight: 500;
  border: none;
  transition: opacity 0.2s;
}
.btn:active { opacity: 0.8; }
.btn-primary {
  background: var(--color-primary);
  color: #ffffff;
}
.btn-accent {
  background: var(--color-accent);
  color: #ffffff;
}
.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--border-color);
}
.btn-danger {
  background: var(--color-danger);
  color: #ffffff;
}
.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
}
.btn-sm {
  padding: 8rpx 20rpx;
  font-size: var(--font-sm);
}
.btn-block {
  display: flex;
  width: 100%;
}
.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: var(--font-xs);
  line-height: 1.4;
}
.tag-blue {
  background: #faf5ed;
  color: #c8a96e;
}
.tag-warm {
  background: #faf5ed;
  color: #c8a96e;
}
.tag-green {
  background: #ecfdf5;
  color: #10b981;
}
.tag-yellow {
  background: #fffbeb;
  color: #f59e0b;
}
.tag-red {
  background: #fef2f2;
  color: #ef4444;
}
.tag-gray {
  background: #f1f5f9;
  color: #64748b;
}

/* 分隔线 */
.divider {
  height: 2rpx;
  background: var(--border-color);
  margin: 24rpx 0;
}

/* 安全区适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
