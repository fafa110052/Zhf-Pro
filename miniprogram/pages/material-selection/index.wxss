/* 完全参照 work-detail 的页面结构 */
.page { min-height: 100vh; background: #f8fafc; }

/* ═══ Loading（height:100vh 填满，含原 tabBar 区域）═══ */
.page-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #f8fafc; }
.loading-dot-pulse { display: flex; gap: 12rpx; }
.dot { width: 14rpx; height: 14rpx; background: #cbd5e1; border-radius: 50%; animation: dotPulse 1.4s ease-in-out infinite both; }
.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse { 0%,80%,100% { transform: scale(0); } 40% { transform: scale(1); } }
.loading-hint { margin-top: 24rpx; font-size: 26rpx; color: #94a3b8; }

/* ═══ Error — 同样全屏 ═══ */
.page-error { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #f8fafc; }
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-msg { font-size: 32rpx; font-weight: 600; color: #475569; margin-bottom: 12rpx; }
.error-hint { font-size: 24rpx; color: #3b82f6; }

/* ═══ 楼盘封面头图 ═══ */
.property-header { position: relative; height: 320rpx; overflow: hidden; }
.property-cover-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.property-header-mask { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(30,41,59,0.55), rgba(37,99,235,0.65)); }
.property-header-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-end; height: 100%; padding: 32rpx; }
.property-name { font-size: 38rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3); }
.property-hint { font-size: 24rpx; color: rgba(255,255,255,0.8); }

/* 搜索 */
.search-bar { padding: 16rpx 24rpx; background: #fff; border-bottom: 1rpx solid #f1f5f9; }
.search-box { display: flex; align-items: center; background: #f1f5f9; border-radius: 16rpx; padding: 12rpx 20rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; color: #1e293b; }
.search-clear { padding: 4rpx 12rpx; font-size: 24rpx; color: #94a3b8; }

/* ═══ 可滚动内容区 — 固定高度避开 header+search+bottom-bar ═══ */
.scroll-body { background: #f8fafc; }
.scroll-body.has-bottom-bar { padding-bottom: 140rpx; }
.scroll-bottom-spacer { height: 40rpx; }

/* 分类 */
.category-section { margin: 16rpx 24rpx; background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.category-header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; background: #f8fafc; }
.category-title-row { display: flex; align-items: center; }
.category-icon { font-size: 20rpx; color: #64748b; margin-right: 16rpx; }
.category-name { font-size: 30rpx; font-weight: 600; color: #1e293b; }
.category-count { font-size: 24rpx; color: #94a3b8; margin-left: 16rpx; }

/* 材料卡片 */
.material-list { border-top: 1rpx solid #f1f5f9; }
.material-card { display: flex; align-items: center; padding: 20rpx 28rpx; border-bottom: 1rpx solid #f8fafc; }
.material-card:last-child { border-bottom: none; }
.material-selected { background: #eff6ff; }
.material-radio { margin-right: 16rpx; flex-shrink: 0; }
.radio-circle { width: 40rpx; height: 40rpx; border-radius: 50%; border: 3rpx solid #cbd5e1; display: flex; align-items: center; justify-content: center; }
.radio-checked { border-color: #3b82f6; background: #3b82f6; }
.radio-dot { font-size: 20rpx; color: #fff; }
.material-image { width: 100rpx; height: 100rpx; border-radius: 12rpx; flex-shrink: 0; background: #f1f5f9; }
.material-image-placeholder { width: 100rpx; height: 100rpx; border-radius: 12rpx; flex-shrink: 0; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.material-info { flex: 1; margin-left: 20rpx; min-width: 0; display: flex; flex-direction: column; }
.material-name { font-size: 28rpx; font-weight: 500; color: #1e293b; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.material-brand { font-size: 24rpx; color: #64748b; margin-top: 4rpx; }
.material-desc { font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.material-price { flex-shrink: 0; text-align: right; margin-left: 16rpx; }
.price-value { font-size: 30rpx; font-weight: 700; color: #ef4444; }
.price-unit { font-size: 22rpx; color: #94a3b8; margin-left: 4rpx; }

/* 底部提交栏 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1rpx solid #e2e8f0; padding: 20rpx 32rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; justify-content: space-between; z-index: 100; }
.bottom-count { font-size: 28rpx; color: #475569; }
.bottom-btn { background: linear-gradient(135deg, #3b82f6, #2563eb); border-radius: 44rpx; padding: 20rpx 48rpx; }
.bottom-btn-text { font-size: 30rpx; font-weight: 600; color: #fff; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #475569; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #94a3b8; text-align: center; }

/* 库存不足 */
.material-out-of-stock { opacity: 0.45; }
.material-card { position: relative; }
.material-stock-badge { position: absolute; top: 12rpx; right: 16rpx; background: #f56c6c; color: #fff; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; z-index: 2; }
