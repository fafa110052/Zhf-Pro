/* 材料选择页 V2.0 — 温暖精致风 */
.page { min-height: 100vh; background: var(--bg-page); }

/* ═══ Loading（height:100vh 填满，含原 tabBar 区域）═══ */
.page-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: var(--bg-page); }
.loading-dot-pulse { display: flex; gap: 12rpx; }
.dot { width: 14rpx; height: 14rpx; background: var(--text-tertiary); border-radius: 50%; animation: dotPulse 1.4s ease-in-out infinite both; }
.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse { 0%,80%,100% { transform: scale(0); } 40% { transform: scale(1); } }
.loading-hint { margin-top: 24rpx; font-size: 26rpx; color: var(--text-tertiary); }

/* ═══ Error — 同样全屏 ═══ */
.page-error { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: var(--bg-page); }
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-msg { font-size: 32rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 12rpx; }
.error-hint { font-size: 24rpx; color: var(--color-accent); }

/* ═══ 楼盘封面头图 — 沉浸式：照片清晰，底部渐变压暗保证文字可读 ═══ */
/* 无封面时回退到品牌暖色渐变，头图仍显得完整 */
.property-header { position: relative; height: 380rpx; overflow: hidden; background: var(--gradient-warm); }
.property-cover-bg { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
/* 底部蒙层：顶部 1/3 照片全清晰，仅底部渐暗承托白色文字 */
.property-header-mask { position: absolute; left: 0; bottom: 0; width: 100%; height: 66%; background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0,0,0,0.35) 45%, rgba(0,0,0,0.75) 100%); }
.property-header-content { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-end; height: 100%; padding: 36rpx 32rpx; }
.property-name { font-size: 40rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.55); }
.property-hint { font-size: 24rpx; color: rgba(255,255,255,0.9); text-shadow: 0 1rpx 6rpx rgba(0,0,0,0.5); }

/* 搜索 */
.search-bar { padding: 16rpx 24rpx; background: var(--bg-card); border-bottom: 1rpx solid var(--border-color); }
.search-box { display: flex; align-items: center; background: #f5f0e8; border-radius: 16rpx; padding: 12rpx 20rpx; }
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 28rpx; color: var(--text-primary); }
.search-clear { padding: 4rpx 12rpx; font-size: 24rpx; color: var(--text-tertiary); }

/* ═══ 可滚动内容区 — 固定高度避开 header+search+bottom-bar ═══ */
.scroll-body { background: var(--bg-page); }
.scroll-body.has-bottom-bar { padding-bottom: 140rpx; }
.scroll-bottom-spacer { height: 40rpx; }

/* 分类 */
.category-section { margin: 16rpx 24rpx; background: var(--bg-card); border-radius: var(--border-radius-lg); overflow: hidden; box-shadow: var(--shadow-sm); }
.category-header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 28rpx; background: var(--bg-page); }
.category-title-row { display: flex; align-items: center; }
.category-icon { font-size: 20rpx; color: var(--text-secondary); margin-right: 16rpx; }
.category-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.category-count { font-size: 24rpx; color: var(--text-tertiary); margin-left: 16rpx; }

/* 材料卡片 */
.material-list { border-top: 1rpx solid var(--border-color); }
.material-card { display: flex; align-items: center; padding: 20rpx 28rpx; border-bottom: 1rpx solid var(--bg-page); }
.material-card:last-child { border-bottom: none; }
.material-selected { background: var(--color-accent-light); }
.material-radio { margin-right: 16rpx; flex-shrink: 0; }
.radio-circle { width: 40rpx; height: 40rpx; border-radius: 50%; border: 3rpx solid var(--text-tertiary); display: flex; align-items: center; justify-content: center; }
.radio-checked { border-color: var(--color-accent); background: var(--color-accent); }
.radio-dot { font-size: 20rpx; color: #fff; }
.material-image { width: 100rpx; height: 100rpx; border-radius: 12rpx; flex-shrink: 0; background: #f5f0e8; }
.material-image-placeholder { width: 100rpx; height: 100rpx; border-radius: 12rpx; flex-shrink: 0; background: #f5f0e8; display: flex; align-items: center; justify-content: center; font-size: 48rpx; }
.material-info { flex: 1; margin-left: 20rpx; min-width: 0; display: flex; flex-direction: column; }
.material-name { font-size: 28rpx; font-weight: 500; color: var(--text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.material-brand { font-size: 24rpx; color: var(--text-secondary); margin-top: 4rpx; }
.material-desc { font-size: 22rpx; color: var(--text-tertiary); margin-top: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.material-price { flex-shrink: 0; text-align: right; margin-left: 16rpx; }
.price-value { font-size: 30rpx; font-weight: 700; color: var(--color-danger); }
.price-unit { font-size: 22rpx; color: var(--text-tertiary); margin-left: 4rpx; }

/* 底部提交栏 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: var(--bg-card); border-top: 1rpx solid var(--border-color); padding: 20rpx 32rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; justify-content: space-between; z-index: 100; }
.bottom-count { font-size: 28rpx; color: var(--text-secondary); }
.bottom-btn { background: var(--gradient-warm); border-radius: 44rpx; padding: 20rpx 48rpx; }
.bottom-btn-text { font-size: 30rpx; font-weight: 600; color: #fff; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: var(--text-tertiary); text-align: center; }

/* 库存不足 */
.material-out-of-stock { opacity: 0.45; }
.material-card { position: relative; }
.material-stock-badge { position: absolute; top: 12rpx; right: 16rpx; background: var(--color-danger); color: #fff; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 8rpx; z-index: 2; }
