<!-- 选材申请详情页 V1.2 — 新增业主验收 -->
<view class="page">
  <!-- ready 之前仅背景色 -->
  <block wx:if="{{ready}}">
    <view wx:if="{{loading}}" class="page-loading">
      <view class="loading-dot-pulse">
        <view class="dot"></view><view class="dot"></view><view class="dot"></view>
      </view>
      <text class="loading-hint">加载中...</text>
    </view>

    <view wx:elif="{{error}}" class="page-error" bindtap="onRetry">
      <text class="error-icon zhficon"></text>
      <text class="error-msg">加载失败</text>
      <text class="error-hint">点击重试</text>
    </view>

    <block wx:elif="{{detail}}">
      <view class="status-header">
        <view class="status-tag {{ORDER_STATUS_MAP[detail.status].colorClass}}">
          <text class="zhficon">{{ORDER_STATUS_MAP[detail.status].icon}}</text><text> {{ORDER_STATUS_MAP[detail.status].label}}</text>
        </view>
        <text class="order-no" bindtap="onCopyOrderNo">{{detail.order_no}} <text class="zhficon"></text></text>
        <text class="order-time">{{detail.created_at}}</text>
      </view>

      <!-- 驳回原因 -->
      <view wx:if="{{detail.status === 'rejected' && detail.reject_reason}}" class="reject-box">
        <text class="reject-label">驳回原因</text>
        <text class="reject-text">{{detail.reject_reason}}</text>
      </view>

      <!-- 材料清单 -->
      <view class="section">
        <view class="section-title"><text>材料清单（{{detail.items.length}}种）</text></view>
        <view wx:for="{{detail.items}}" wx:key="category_name" class="item-row">
          <view class="item-tag">{{item.category_name}}</view>
          <view class="item-info">
            <text class="item-name">{{item.material_name}}</text>
            <text class="item-brand">{{item.brand}}</text>
          </view>
          <text class="item-price">¥{{item.unit_price}}{{item.price_unit}}</text>
        </view>
      </view>

      <!-- 申请信息 -->
      <view class="section">
        <view class="section-title"><text>申请信息</text></view>
        <view class="info-row"><text class="info-label">楼盘</text><text class="info-value">{{detail.property_name}}</text></view>
        <view class="info-row"><text class="info-label">房号</text><text class="info-value">{{detail.room_number}}</text></view>
        <view class="info-row"><text class="info-label">联系人</text><text class="info-value">{{detail.applicant_name}}</text></view>
        <view class="info-row"><text class="info-label">电话</text><text class="info-value">{{detail.applicant_phone}}</text></view>
        <view wx:if="{{detail.remark}}" class="info-row"><text class="info-label">备注</text><text class="info-value">{{detail.remark}}</text></view>
      </view>

      <!-- 服务人员 -->
      <view wx:if="{{detail.designer || detail.supervisor}}" class="section">
        <view class="section-title"><text>服务人员</text></view>
        <view wx:if="{{detail.designer}}" class="info-row"><text class="info-label">设计师</text><text class="info-value">{{detail.designer.name}}  {{detail.designer.phone}}</text></view>
        <view wx:if="{{detail.supervisor}}" class="info-row"><text class="info-label">监理</text><text class="info-value">{{detail.supervisor.name}}  {{detail.supervisor.phone}}</text></view>
      </view>

      <!-- 设计阶段（整屋设计，独立于施工） -->
      <view wx:if="{{designPhase}}" class="section">
        <view class="section-title"><text><text class="zhficon"></text> 设计阶段</text></view>
        <view class="design-status-row">
          <view class="design-status-tag {{designPhase.status === 'design_admin_approved' ? 'tag-blue' : designPhase.status === 'engineer_design_confirmed' ? 'tag-blue' : designPhase.status.includes('rejected') || designPhase.status === 'owner_design_disputed' ? 'tag-red' : designPhase.status === 'owner_design_reviewed' ? 'tag-green' : 'tag-orange'}}">
            <text>{{designPhase.status === 'design_uploaded' ? '待设计总监审核' : designPhase.status === 'design_director_approved' ? '待管理员审核' : designPhase.status === 'design_admin_approved' ? '待业主审核' : designPhase.status === 'design_director_rejected' ? '设计总监已驳回' : designPhase.status === 'design_admin_rejected' ? '管理员已驳回' : designPhase.status === 'owner_design_reviewed' ? '设计已确认' : designPhase.status === 'owner_design_disputed' ? '业主已驳回' : PHASE_STATUS_MAP[designPhase.status].label}}</text>
          </view>
        </view>
        <!-- 设计人员 -->
        <view class="phase-persons-bar">
          <text>设计师：{{designDesigner ? designDesigner.name : '暂无分配'}}</text>
          <text class="person-sep">|</text>
          <text>设计总监：{{designDirector ? designDirector.name : '暂无分配'}}</text>
        </view>
        <!-- 设计图 -->
        <view wx:if="{{designPhase.design_images && designPhase.design_images.length > 0}}" class="image-grid" style="margin-top:20rpx;">
          <view wx:for="{{designPhase.design_images}}" wx:key="*this" class="image-item">
            <image lazy-load class="image-thumb" src="{{item}}" mode="aspectFill"
              data-url="{{item}}" bindtap="onPreviewDesignImage" />
          </view>
        </view>
        <!-- 业主操作：通过/驳回设计 -->
        <view wx:if="{{designPhase.status === 'design_admin_approved'}}" class="action-row">
          <button class="btn-dispute" bindtap="onOpenDesignReject" disabled="{{designActing}}">驳回设计</button>
          <button class="btn-accept" bindtap="onApproveDesign" disabled="{{designActing}}" loading="{{designActing}}">通过设计</button>
        </view>
      </view>

      <!-- 施工进度（5阶段）— 仅进入施工阶段后显示 -->
      <view wx:if="{{showConstruction}}" class="section">
        <view class="section-title"><text><text class="zhficon"></text> 施工进度</text></view>
        <view class="phase-progress">
          <block wx:for="{{detail.construction.phases}}" wx:key="phase_order">
            <view class="phase-dot {{item.status === 'owner_accepted' ? 'phase-dot-done' : item.phase_order < detail.current_phase_order ? 'phase-dot-done' : item.phase_order === detail.current_phase_order ? 'phase-dot-active' : 'phase-dot-locked'}}">{{item.phase_order}}</view>
            <view wx:if="{{index < 4}}" class="phase-line {{item.status === 'owner_accepted' || item.phase_order < detail.current_phase_order ? 'phase-line-done' : 'phase-line-pending'}}"></view>
          </block>
        </view>
        <view class="phase-labels">
          <text wx:for="{{detail.construction.phases}}" wx:key="phase_order" class="phase-label-text {{item.phase_order === detail.current_phase_order ? 'phase-label-current' : ''}}">{{item.phase_type === 'demolition' ? '打拆' : item.phase_type === 'water_electric' ? '水电' : item.phase_type === 'painting' ? '油工' : item.phase_type === 'material_install' ? '主材' : '竣工'}}</text>
        </view>
        <!-- 施工人员 -->
        <view class="phase-persons-bar">
          <text>工程师：{{constructionEngineer ? constructionEngineer.name : '暂无分配'}}</text>
          <text class="person-sep">|</text>
          <text>工程总监：{{constructionEngineeringDirector ? constructionEngineeringDirector.name : '暂无分配'}}</text>
        </view>
        <!-- 各阶段详情 -->
        <block wx:for="{{detail.construction.phases}}" wx:key="phase_order">
          <view wx:if="{{item.status !== 'assigned' && item.phase_order <= detail.current_phase_order}}" class="phase-info-card">
            <view class="phase-info-title">{{item.phase_type === 'demolition' ? '打拆' : item.phase_type === 'water_electric' ? '水电' : item.phase_type === 'painting' ? '油工' : item.phase_type === 'material_install' ? '主材安装' : '竣工'}} · {{item.status === 'owner_accepted' ? '已完成' : item.status === 'construction_admin_approved' ? '待验收' : item.status.includes('rejected') || item.status === 'owner_disputed' ? '已驳回' : '进行中'}}</view>
            <view wx:if="{{item.construction_images && item.construction_images.length > 0}}" class="phase-images-mini">
              <image lazy-load wx:for="{{item.construction_images}}" wx:for-item="img" wx:key="*this"
                class="phase-img-mini" src="{{img}}" mode="aspectFill"
                data-url="{{img}}" bindtap="onPreviewImage" />
            </view>
            <view wx:if="{{item.construction_description}}" class="phase-remark"><text class="phase-remark-label">施工描述：</text><text>{{item.construction_description}}</text></view>
            <view wx:if="{{item.engineering_director_remark}}" class="phase-remark"><text class="phase-remark-label">工程总监备注：</text><text>{{item.engineering_director_remark}}</text></view>
            <view wx:if="{{item.admin_construction_remark}}" class="phase-remark"><text class="phase-remark-label">管理员备注：</text><text>{{item.admin_construction_remark}}</text></view>
            <view class="phase-persons">
              <text wx:if="{{item.engineer}}">工程师：{{item.engineer.name}}</text>
              <text wx:if="{{item.engineering_director}}" class="person-sep-block">|</text>
              <text wx:if="{{item.engineering_director}}">工程总监：{{item.engineering_director.name}}</text>
              <text wx:if="{{!item.engineer && !item.engineering_director}}" class="person-none">暂无分配 · 待派单</text>
            </view>
          </view>
        </block>
      </view>

      <!-- 设计驳回弹窗 -->
      <view wx:if="{{designRejectOpen}}" class="modal-mask" bindtap="onCloseDesignReject">
        <view class="modal-panel" catchtap="">
          <view class="modal-title"><text>驳回设计图</text></view>
          <textarea value="{{designRejectReason}}" placeholder="请填写驳回原因（必填）" maxlength="500"
            bindinput="onDesignReasonInput" class="reject-textarea" />
          <view class="modal-image-row">
            <image lazy-load wx:for="{{designRejectImages}}" wx:key="*this" class="modal-thumb" src="{{item}}" mode="aspectFill"
              data-index="{{index}}" bindtap="onDesignRemoveImage" />
            <view wx:if="{{designRejectImages.length < 9}}" class="modal-add-btn" bindtap="onDesignChooseImages">
              <text>+</text>
            </view>
          </view>
          <view class="modal-btns">
            <button class="btn-cancel" bindtap="onCloseDesignReject">取消</button>
            <button class="btn-confirm" bindtap="onSubmitDesignDispute" loading="{{designRejectUploading}}">提交驳回</button>
          </view>
        </view>
      </view>

      <!-- ✅ 验收（业主） -->
      <view wx:if="{{activePhase && activePhase.status === 'construction_admin_approved'}}" class="section">
        <view class="section-title"><text><text class="zhficon"></text> 验收</text></view>
        <view wx:if="{{activePhase.construction_images && activePhase.construction_images.length > 0}}" class="image-grid">
          <view wx:for="{{activePhase.construction_images}}" wx:key="*this" class="image-item">
            <image lazy-load class="image-thumb" src="{{item}}" mode="aspectFill"
              data-url="{{item}}" bindtap="onPreviewImage" />
          </view>
        </view>
        <view wx:else class="empty-hint"><text>暂无完工图</text></view>
        <view class="action-row">
          <button class="btn-dispute" bindtap="onOpenDispute" disabled="{{acceptActing}}">提出异议</button>
          <button class="btn-accept" bindtap="onAcceptPhase" disabled="{{acceptActing}}" loading="{{acceptActing}}">通过验收</button>
        </view>
      </view>

      <!-- 验收异议弹窗 -->
      <view wx:if="{{disputeOpen}}" class="modal-mask" bindtap="onCloseDispute">
        <view class="modal-panel" catchtap="">
          <view class="modal-title"><text>提出异议</text></view>
          <textarea value="{{disputeReason}}" placeholder="请描述问题（必填）" maxlength="500"
            bindinput="onDisputeReasonInput" class="reject-textarea" />
          <view class="modal-image-row">
            <image lazy-load wx:for="{{disputeImages}}" wx:key="*this" class="modal-thumb" src="{{item}}" mode="aspectFill"
              data-index="{{index}}" bindtap="onDisputeRemoveImage" />
            <view wx:if="{{disputeImages.length < 9}}" class="modal-add-btn" bindtap="onDisputeChooseImages">
              <text>+</text>
            </view>
          </view>
          <view class="modal-btns">
            <button class="btn-cancel" bindtap="onCloseDispute">取消</button>
            <button class="btn-confirm" bindtap="onSubmitDispute" loading="{{disputeUploading}}">提交异议</button>
          </view>
        </view>
      </view>

      <!-- 进度跟踪 -->
      <view class="section">
        <view class="section-title"><text>进度跟踪</text></view>
        <view class="timeline">
          <view wx:for="{{detail.logs}}" wx:key="created_at" class="timeline-item">
            <view class="timeline-dot {{index === 0 ? 'dot-active' : ''}}"></view>
            <view wx:if="{{index < detail.logs.length - 1}}" class="timeline-line"></view>
            <view class="timeline-content">
              <text class="timeline-detail">{{item.detail}}</text>
              <text class="timeline-time">{{item.created_at}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </block>
  </block>

</view>
