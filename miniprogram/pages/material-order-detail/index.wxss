.page { min-height: 100vh; background: #f8fafc; }

/* Loading — height:100vh 填满全屏 */
.page-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #f8fafc; }
.loading-dot-pulse { display: flex; gap: 12rpx; }
.dot { width: 14rpx; height: 14rpx; background: #cbd5e1; border-radius: 50%; animation: dotPulse 1.4s ease-in-out infinite both; }
.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse { 0%,80%,100% { transform: scale(0); } 40% { transform: scale(1); } }
.loading-hint { margin-top: 24rpx; font-size: 26rpx; color: #94a3b8; }

/* Error */
.page-error { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #f8fafc; }
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-msg { font-size: 32rpx; font-weight: 600; color: #475569; margin-bottom: 12rpx; }
.error-hint { font-size: 24rpx; color: #3b82f6; }

/* 状态头 */
.status-header { background: linear-gradient(135deg, #3b82f6, #2563eb); padding: 40rpx 32rpx; display: flex; flex-direction: column; align-items: flex-start; }
.status-tag { padding: 8rpx 24rpx; border-radius: 20rpx; font-size: 28rpx; margin-bottom: 16rpx; }
.tag-yellow { background: rgba(255,255,255,0.2); color: #fff; }
.tag-green  { background: rgba(255,255,255,0.2); color: #fff; }
.tag-red    { background: rgba(255,255,255,0.2); color: #fff; }
.tag-blue   { background: rgba(255,255,255,0.2); color: #fff; }
.tag-orange { background: rgba(255,255,255,0.2); color: #fff; }
.order-no { font-size: 24rpx; color: rgba(255,255,255,0.7); letter-spacing: 2rpx; margin-bottom: 8rpx; }
.order-time { font-size: 22rpx; color: rgba(255,255,255,0.5); }

/* 驳回 */
.reject-box { margin: 20rpx 24rpx; background: #fef2f2; border: 1rpx solid #fecaca; border-radius: 12rpx; padding: 20rpx 24rpx; }
.reject-label { font-size: 24rpx; color: #dc2626; font-weight: 600; display: block; margin-bottom: 8rpx; }
.reject-text { font-size: 26rpx; color: #991b1b; line-height: 1.5; }

/* 完成备注 */
.complete-box { margin: 20rpx 24rpx; background: #eff6ff; border: 1rpx solid #bfdbfe; border-radius: 12rpx; padding: 20rpx 24rpx; }
.complete-label { font-size: 24rpx; color: #2563eb; font-weight: 600; display: block; margin-bottom: 8rpx; }
.complete-text { font-size: 26rpx; color: #1e40af; line-height: 1.5; }

/* 区块 */
.section { margin: 20rpx 24rpx; background: #fff; border-radius: 16rpx; padding: 24rpx 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.section-title { font-size: 30rpx; font-weight: 600; color: #1e293b; margin-bottom: 16rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f1f5f9; }

/* 材料项 */
.item-row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f8fafc; }
.item-row:last-child { border-bottom: none; }
.item-tag { background: #eff6ff; color: #3b82f6; font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 8rpx; margin-right: 16rpx; flex-shrink: 0; }
.item-info { flex: 1; min-width: 0; }
.item-name { font-size: 28rpx; color: #1e293b; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-brand { font-size: 24rpx; color: #94a3b8; }
.item-price { font-size: 28rpx; font-weight: 600; color: #ef4444; white-space: nowrap; margin-left: 12rpx; }

/* 信息行 */
.info-row { display: flex; align-items: center; padding: 14rpx 0; }
.info-row + .info-row { border-top: 1rpx solid #f8fafc; }
.info-label { font-size: 26rpx; color: #94a3b8; width: 120rpx; flex-shrink: 0; }
.info-value { font-size: 26rpx; color: #1e293b; flex: 1; }

/* 时间线 */
.timeline { padding-left: 16rpx; }
.timeline-item { position: relative; padding-left: 36rpx; padding-bottom: 28rpx; }
.timeline-item:last-child { padding-bottom: 0; }
.timeline-dot { position: absolute; left: 0; top: 6rpx; width: 20rpx; height: 20rpx; border-radius: 50%; background: #cbd5e1; }
.timeline-dot.dot-active { background: #3b82f6; box-shadow: 0 0 0 6rpx rgba(59,130,246,0.15); }
.timeline-line { position: absolute; left: 9rpx; top: 28rpx; bottom: 0; width: 2rpx; background: #e2e8f0; }
.timeline-content { display: flex; flex-direction: column; }
.timeline-detail { font-size: 26rpx; color: #334155; line-height: 1.5; }
.timeline-time { font-size: 22rpx; color: #94a3b8; margin-top: 6rpx; }

/* V1.3 施工进度 */
.phase-progress { display: flex; align-items: center; gap: 4rpx; padding: 12rpx 0; }
.phase-dot { width: 40rpx; height: 40rpx; border-radius: 20rpx; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 700; color: #fff; flex-shrink: 0; }
.phase-dot-done { background: #22c55e; }
.phase-dot-active { background: #3b82f6; }
.phase-dot-locked { background: #e2e8f0; color: #94a3b8; }
.phase-line { flex: 1; height: 4rpx; }
.phase-line-done { background: #22c55e; }
.phase-line-pending { background: #e2e8f0; }
.phase-labels { display: flex; justify-content: space-between; margin-top: 6rpx; }
.phase-label-text { font-size: 20rpx; color: #94a3b8; }
.phase-label-current { color: #1e293b; font-weight: 600; }
.phase-info-card { margin-top: 16rpx; padding: 16rpx; background: #f8fafc; border-radius: 10rpx; }
.phase-info-title { font-size: 24rpx; font-weight: 600; color: #334155; margin-bottom: 6rpx; }
.phase-persons { font-size: 22rpx; color: #64748b; line-height: 1.6; display: flex; flex-wrap: wrap; gap: 6rpx; }
.person-sep-block { color: #cbd5e1; margin: 0 6rpx; }
.person-none { color: #94a3b8; font-style: italic; }
.phase-images-mini { display: flex; flex-wrap: wrap; gap: 10rpx; margin: 10rpx 0; }
.phase-img-mini { width: 120rpx; height: 120rpx; border-radius: 8rpx; border: 1rpx solid #e2e8f0; }

/* 人员信息条 */
.phase-persons-bar { display: flex; align-items: center; gap: 12rpx; margin-top: 16rpx; padding: 16rpx 20rpx; background: #f8fafc; border-radius: 10rpx; font-size: 24rpx; color: #475569; line-height: 1.5; }
.person-sep { color: #cbd5e1; }

/* 设计阶段状态 */
.design-status-row { margin-top: 12rpx; }
.design-status-tag { display: inline-flex; padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 26rpx; font-weight: 600; }
.design-status-tag.tag-blue { background: #dbeafe; color: #1e40af; }
.design-status-tag.tag-green { background: #dcfce7; color: #166534; }
.design-status-tag.tag-orange { background: #fff7ed; color: #9a3412; }
.design-status-tag.tag-red { background: #fee2e2; color: #991b1b; }

.bottom-spacer { height: 60rpx; }
.bottom-spacer-action { height: 160rpx; }

/* ─── 验收通过 ─── */
.accepted-box { margin: 20rpx 24rpx; background: #f0fdf4; border: 1rpx solid #bbf7d0; border-radius: 12rpx; padding: 24rpx; display: flex; align-items: center; gap: 16rpx; }
.accepted-icon { font-size: 48rpx; flex-shrink: 0; }
.accepted-label { font-size: 28rpx; font-weight: 600; color: #16a34a; display: block; }
.accepted-text { font-size: 24rpx; color: #15803d; margin-top: 4rpx; display: block; }

/* ─── 异议信息 ─── */
.disputed-box { margin: 20rpx 24rpx; background: #fff7ed; border: 1rpx solid #fed7aa; border-radius: 12rpx; padding: 20rpx 24rpx; }
.disputed-label { font-size: 26rpx; font-weight: 600; color: #c2410c; display: block; margin-bottom: 8rpx; }
.disputed-text { font-size: 26rpx; color: #9a3412; line-height: 1.5; display: block; }
.disputed-images { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.disputed-image { width: 140rpx; height: 140rpx; border-radius: 8rpx; border: 1rpx solid #fed7aa; }
.disputed-hint { font-size: 22rpx; color: #fb923c; margin-top: 12rpx; display: block; }

/* ─── 底部操作栏 ─── */
.action-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1rpx solid #e2e8f0; padding: 20rpx 32rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); display: flex; gap: 20rpx; z-index: 30; }
.action-btn { flex: 1; height: 88rpx; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; padding: 0; margin: 0; }
.action-btn::after { border: none; }
.dispute-btn { background: #fff; color: #ea580c; border: 2rpx solid #fdba74; }
.accept-btn { background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff; border: none; }

/* ─── 异议弹窗 ─── */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 50; }
.modal-panel { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 24rpx 24rpx 0 0; z-index: 51; max-height: 85vh; display: flex; flex-direction: column; }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 32rpx; border-bottom: 1rpx solid #f1f5f9; flex-shrink: 0; }
.modal-title { font-size: 32rpx; font-weight: 700; color: #1e293b; }
.modal-close { font-size: 36rpx; color: #94a3b8; padding: 8rpx; }
.modal-body { flex: 1; overflow-y: auto; padding: 24rpx 32rpx; }
.modal-field { margin-bottom: 24rpx; }
.modal-label { font-size: 28rpx; font-weight: 600; color: #334155; display: block; margin-bottom: 12rpx; }
.modal-label-hint { font-weight: 400; color: #94a3b8; font-size: 24rpx; }
.modal-textarea { width: 100%; height: 180rpx; background: #f8fafc; border: 1rpx solid #e2e8f0; border-radius: 12rpx; padding: 16rpx; font-size: 26rpx; box-sizing: border-box; }
.modal-count { text-align: right; font-size: 22rpx; color: #94a3b8; margin-top: 8rpx; display: block; }

/* 图片网格 */
.image-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.image-item { position: relative; width: 160rpx; height: 160rpx; }
.image-thumb { width: 100%; height: 100%; border-radius: 12rpx; }
.image-remove { position: absolute; top: -10rpx; right: -10rpx; width: 40rpx; height: 40rpx; background: #ef4444; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; }
.image-add { width: 160rpx; height: 160rpx; border: 2rpx dashed #cbd5e1; border-radius: 12rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4rpx; }
.add-icon { font-size: 48rpx; color: #94a3b8; line-height: 1; }
.add-text { font-size: 22rpx; color: #94a3b8; }

/* 弹窗底部 */
.modal-footer { display: flex; gap: 20rpx; padding: 24rpx 32rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #f1f5f9; flex-shrink: 0; }
.modal-cancel { flex: 1; height: 88rpx; border-radius: 44rpx; font-size: 28rpx; font-weight: 600; background: #f1f5f9; color: #64748b; display: flex; align-items: center; justify-content: center; padding: 0; margin: 0; }
.modal-submit { flex: 1; height: 88rpx; border-radius: 44rpx; font-size: 28rpx; font-weight: 600; background: linear-gradient(135deg, #ea580c, #c2410c); color: #fff; display: flex; align-items: center; justify-content: center; padding: 0; margin: 0; }
.modal-cancel::after, .modal-submit::after { border: none; }

/* ─── 审核设计图 & 验收 操作区 ─── */
.action-row { display: flex; gap: 20rpx; margin-top: 20rpx; }
.action-row button { flex: 1; height: 80rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; padding: 0; margin: 0; }
.action-row button::after { border: none; }
.btn-dispute { background: #fff; color: #ea580c; border: 2rpx solid #fdba74; }
.btn-accept { background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff; }
.empty-hint { font-size: 24rpx; color: #94a3b8; text-align: center; padding: 24rpx 0; }

/* ─── 审核/异议弹窗元素 ─── */
.reject-textarea { width: 100%; min-height: 160rpx; background: #f8fafc; border: 1rpx solid #e2e8f0; border-radius: 12rpx; padding: 16rpx; font-size: 26rpx; box-sizing: border-box; margin-top: 16rpx; }
.modal-image-row { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 16rpx 0; }
.modal-thumb { width: 140rpx; height: 140rpx; border-radius: 10rpx; border: 1rpx solid #e2e8f0; }
.modal-add-btn { width: 140rpx; height: 140rpx; border: 2rpx dashed #cbd5e1; border-radius: 10rpx; display: flex; align-items: center; justify-content: center; }
.modal-add-btn text { font-size: 60rpx; color: #94a3b8; line-height: 1; }
.modal-btns { display: flex; gap: 20rpx; padding-top: 16rpx; }
.modal-btns button { flex: 1; height: 80rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; padding: 0; margin: 0; }
.modal-btns button::after { border: none; }
.btn-cancel { background: #f1f5f9; color: #64748b; }
.btn-confirm { background: linear-gradient(135deg, #ea580c, #c2410c); color: #fff; }
