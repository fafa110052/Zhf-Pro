<!--
  作品管理列表（设计师端）
  状态筛选 → 作品列表 → 编辑/删除/提交
-->
<view class="page">

  <!-- ═══ 状态 Tab ═══ -->
  <view class="tab-bar">
    <view class="tab-list">
      <text
        wx:for="{{statusTabs}}"
        wx:key="key"
        class="tab-item {{activeStatus === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onStatusTap"
      >{{item.label}}</text>
    </view>
    <view class="tab-divider"></view>
  </view>

  <!-- ═══ 初始 Loading ═══ -->
  <view wx:if="{{initialLoading}}" class="loading-skeleton">
    <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="skeleton-card">
      <view class="skeleton-cover"></view>
      <view class="skeleton-body">
        <view class="skeleton-line skeleton-line-title"></view>
        <view class="skeleton-line skeleton-line-short"></view>
      </view>
    </view>
  </view>

  <!-- ═══ 错误 ═══ -->
  <view wx:elif="{{error}}" class="error-state" bindtap="onPullDownRefresh">
    <view class="error-icon-wrap">
      <text class="error-icon">!</text>
    </view>
    <text class="error-title">加载失败</text>
    <text class="error-desc">点击屏幕重新加载</text>
  </view>

  <!-- ═══ 作品列表 ═══ -->
  <block wx:else>
    <!-- 节点回收提示 -->
    <view wx:if="{{trimmedCount > 0}}" class="trimmed-notice">
      <text>已折叠 {{trimmedCount}} 个较早作品</text>
    </view>

    <view wx:if="{{works.length > 0}}" class="work-list">
      <view
        wx:for="{{works}}"
        wx:key="id"
        class="work-card {{item.review_status !== 'approved' ? 'work-card-locked' : ''}}"
        data-id="{{item.id}}"
        data-status="{{item.review_status}}"
        bindtap="onWorkTap"
      >
        <!-- 封面 -->
        <view class="card-cover">
          <image
            wx:if="{{item.cover_url}}"
            class="cover-img"
            src="{{item.cover_url}}"
            mode="aspectFill"
            lazy-load
          />
          <view wx:else class="cover-placeholder">
            <text class="cover-placeholder-dot">◇</text>
          </view>
        </view>

        <!-- 信息区 -->
        <view class="card-body">
          <view class="card-header">
            <text class="card-title">{{item.title || '未命名作品'}}</text>
            <view class="status-dot {{item.status_class}}">
              <text>{{item.status_label}}</text>
            </view>
          </view>

          <view class="card-meta">
            <text wx:if="{{item.house_type_name}}" class="meta-tag">{{item.house_type_name}}</text>
            <text wx:if="{{item.style_category_name}}" class="meta-tag">{{item.style_category_name}}</text>
            <text class="card-date">{{item.created_at_text}}</text>
          </view>

          <!-- 驳回原因 -->
          <view wx:if="{{item.review_status === 'rejected' && item.reject_reason}}" class="reject-reason">
            <text>{{item.reject_reason}}</text>
          </view>

          <!-- 操作按钮 → 仅草稿/已驳回显示 -->
          <view wx:if="{{item.review_status === 'draft' || item.review_status === 'rejected'}}" class="card-actions">
            <view class="btn-action btn-edit" data-id="{{item.id}}" catchtap="onEdit">编辑</view>
            <view class="btn-action btn-submit" data-id="{{item.id}}" catchtap="onSubmit">提交审核</view>
            <view class="btn-action btn-delete" data-id="{{item.id}}" catchtap="onDelete">删除</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loading}}" class="load-more">
      <view class="load-more-dots">
        <view class="dot"></view><view class="dot"></view><view class="dot"></view>
      </view>
    </view>
    <view wx:elif="{{!hasMore && works.length > 0}}" class="load-more">
      <text class="load-more-text">全部加载完成</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && works.length === 0}}" class="empty-state">
      <view class="empty-illustration">
        <text class="empty-icon">+</text>
      </view>
      <text class="empty-title">暂无作品</text>
      <text class="empty-desc">上传您的第一个装修案例</text>
      <view class="empty-btn" bindtap="onCreate">发布新作品</view>
    </view>
  </block>

  <!-- ═══ 底部新建按钮 ═══ -->
  <view wx:if="{{works.length > 0}}" class="create-fab" bindtap="onCreate">
    <text class="fab-text">发布作品</text>
  </view>

</view>
