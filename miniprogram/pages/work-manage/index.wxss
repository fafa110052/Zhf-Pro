/**
 * 作品管理列表样式
 */
.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ═══ 节点回收提示 ═══ */
.trimmed-notice {
  display: flex;
  justify-content: center;
  padding: 16rpx 24rpx;
  margin: 16rpx 24rpx 0;
  background: #fefce8;
  border-radius: 8rpx;
  border: 2rpx solid #fde68a;
}

.trimmed-notice text {
  font-size: 22rpx;
  color: #a16207;
}

/* ═══ 状态 Tab ═══ */
.tab-scroll {
  background: var(--bg-card);
  border-bottom: 2rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-scroll-view {
  white-space: nowrap;
}

.tab-list {
  display: inline-flex;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-block;
  padding: 20rpx 24rpx;
  font-size: var(--font-base);
  color: var(--text-secondary);
  position: relative;
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 24rpx;
  right: 24rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* ═══ 列表 ═══ */
.work-list {
  padding: 16rpx 24rpx;
}

.work-item {
  display: flex;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius);
  box-shadow: var(--shadow-sm);
}

.work-item:active {
  opacity: 0.85;
}

/* 封面 */
.work-cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: var(--border-radius-sm);
  overflow: hidden;
  background: #f1f5f9;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

/* 内容 */
.work-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.work-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.work-title {
  flex: 1;
  font-size: var(--font-base);
  font-weight: 500;
  color: var(--text-primary);
  margin-right: 12rpx;
}

.work-date {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}

/* 操作按钮 */
.work-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.action-btn:active {
  opacity: 0.7;
  transform: scale(0.95);
}

.action-icon {
  font-size: 24rpx;
}

.action-edit {
  color: #2563eb;
  background: #eff6ff;
  border-color: #bfdbfe;
}

.action-submit {
  color: #059669;
  background: #ecfdf5;
  border-color: #a7f3d0;
}

.action-delete {
  color: #dc2626;
  background: #fef2f2;
  border-color: #fecaca;
}

/* 未通过审核 → 不可点击样式 */
.work-item-locked {
  opacity: 0.6;
}

/* ═══ 状态 ═══ */
.page-loading,
.loading-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
  color: var(--text-tertiary);
  font-size: var(--font-sm);
}

.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.error-text {
  font-size: var(--font-base);
  color: var(--text-secondary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-tertiary);
}

/* ═══ 悬浮按钮 ═══ */
.create-fab {
  position: fixed;
  bottom: 48rpx;
  right: 48rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: var(--color-primary);
  box-shadow: 0 8rpx 24rpx rgba(30, 41, 59, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.create-fab:active {
  opacity: 0.8;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}
