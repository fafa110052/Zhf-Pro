.page{min-height:100vh;background:#f8fafc}
.page-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;background:#f8fafc}
.loading-dot-pulse{display:flex;gap:12rpx}
.dot{width:14rpx;height:14rpx;background:#cbd5e1;border-radius:50%;animation:dotPulse 1.4s ease-in-out infinite both}
.dot:nth-child(1){animation-delay:0s}.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
@keyframes dotPulse{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}
.loading-hint{margin-top:24rpx;font-size:26rpx;color:#94a3b8}
.page-error{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;background:#f8fafc}
.error-icon{font-size:80rpx;margin-bottom:24rpx}.error-msg{font-size:32rpx;font-weight:600;color:#475569;margin-bottom:12rpx}
.error-hint{font-size:24rpx;color:#3b82f6}
.status-header{background:linear-gradient(135deg,#3b82f6,#2563eb);padding:40rpx 32rpx;display:flex;flex-direction:column;align-items:flex-start}
.status-tag{padding:8rpx 24rpx;border-radius:20rpx;font-size:28rpx;margin-bottom:16rpx}
.tag-yellow{background:rgba(255,255,255,.2);color:#fff}.tag-green{background:rgba(255,255,255,.2);color:#fff}
.tag-red{background:rgba(255,255,255,.2);color:#fff}.tag-blue{background:rgba(255,255,255,.2);color:#fff}
.tag-orange{background:rgba(255,255,255,.2);color:#fff}
.order-no{font-size:24rpx;color:rgba(255,255,255,.7);letter-spacing:2rpx}
.section{margin:20rpx 24rpx;background:#fff;border-radius:16rpx;padding:24rpx 28rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}
.section-title{font-size:30rpx;font-weight:600;color:#1e293b;margin-bottom:16rpx;padding-bottom:16rpx;border-bottom:1rpx solid #f1f5f9}
.image-grid{display:flex;flex-wrap:wrap;gap:12rpx}
.image-thumb{width:210rpx;height:210rpx;border-radius:12rpx}
.image-thumb-small{width:140rpx;height:140rpx;border-radius:12rpx}
.info-row{display:flex;align-items:center;padding:14rpx 0}
.info-row+.info-row{border-top:1rpx solid #f8fafc}
.info-label{font-size:26rpx;color:#94a3b8;width:120rpx;flex-shrink:0}
.info-value{font-size:26rpx;color:#1e293b;flex:1}
.bottom-spacer{height:120rpx}
.action-bar{position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1rpx solid #e2e8f0;padding:20rpx 32rpx;padding-bottom:calc(20rpx + env(safe-area-inset-bottom));display:flex;gap:20rpx;z-index:30}
.action-btn{flex:1;height:88rpx;border-radius:44rpx;font-size:30rpx;font-weight:600;display:flex;align-items:center;justify-content:center;padding:0;margin:0}
.action-btn::after{border:none}
.dispute-btn{background:#fff;color:#ea580c;border:2rpx solid #fdba74}
.accept-btn{background:linear-gradient(135deg,#22c55e,#16a34a);color:#fff;border:none}
.modal-mask{position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:50}
.modal-panel{position:fixed;bottom:0;left:0;right:0;background:#fff;border-radius:24rpx 24rpx 0 0;z-index:51;max-height:85vh;display:flex;flex-direction:column}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:28rpx 32rpx;border-bottom:1rpx solid #f1f5f9;flex-shrink:0}
.modal-title{font-size:32rpx;font-weight:700;color:#1e293b}.modal-close{font-size:36rpx;color:#94a3b8;padding:8rpx}
.modal-body{flex:1;overflow-y:auto;padding:24rpx 32rpx}
.modal-field{margin-bottom:24rpx}
.modal-label{font-size:28rpx;font-weight:600;color:#334155;display:block;margin-bottom:12rpx}
.modal-textarea{width:100%;height:180rpx;background:#f8fafc;border:1rpx solid #e2e8f0;border-radius:12rpx;padding:16rpx;font-size:26rpx;box-sizing:border-box}
.modal-count{text-align:right;font-size:22rpx;color:#94a3b8;margin-top:8rpx;display:block}
.modal-footer{display:flex;gap:20rpx;padding:24rpx 32rpx;padding-bottom:calc(24rpx + env(safe-area-inset-bottom));border-top:1rpx solid #f1f5f9;flex-shrink:0}
.modal-cancel{flex:1;height:88rpx;border-radius:44rpx;font-size:28rpx;font-weight:600;background:#f1f5f9;color:#64748b;display:flex;align-items:center;justify-content:center;padding:0;margin:0}
.modal-submit{flex:1;height:88rpx;border-radius:44rpx;font-size:28rpx;font-weight:600;background:linear-gradient(135deg,#ea580c,#c2410c);color:#fff;display:flex;align-items:center;justify-content:center;padding:0;margin:0}
.modal-cancel::after,.modal-submit::after{border:none}
