/**
 * 登录页样式 V2.1 — 温暖精致风
 */

.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ═══ Logo 区域 ═══ */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 80rpx;
}

.logo-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.logo-title {
  margin-top: 28rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}

/* ═══ 登录区 ═══ */
.login-actions {
  width: 100%;
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

/* 手机号输入框 */
.phone-input-wrap {
  width: 100%;
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 8rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--border-color);
  margin-bottom: 48rpx;
  box-sizing: border-box;
}

.phone-input {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  text-align: center;
  box-sizing: border-box;
}

.phone-placeholder {
  color: var(--text-placeholder);
}

/* 手机号登录按钮 */
.phone-btn {
  width: 100%;
  height: 88rpx;
  background: var(--bg-card);
  color: var(--color-accent);
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: 2rpx solid var(--color-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
}
.phone-btn::after {
  border: none;
}

/* 手机号快捷登录按钮 */
.wechat-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  background: var(--gradient-warm);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(200, 169, 110, 0.3);
}
.wechat-btn::after {
  border: none;
}

.terms-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ═══ 协议勾选 ═══ */
.terms-section {
  width: 100%;
  padding: 48rpx 0 0;
}

.terms-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  flex-wrap: wrap;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
  background: var(--bg-card);
}

.checkbox.checked {
  background: var(--color-accent);
  border-color: var(--color-accent);
}

.check-mark {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

.terms-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 40rpx;
}

.terms-link {
  font-size: 26rpx;
  color: var(--color-accent);
  line-height: 40rpx;
  text-decoration: underline;
  padding: 0 2rpx;
}

.input-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ═══ 自定义协议弹窗 ═══ */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 560rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.modal-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 44rpx;
  text-align: center;
  margin-bottom: 36rpx;
}

.modal-btns {
  width: 100%;
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn-cancel {
  background: #f5f0e8;
  color: var(--text-secondary);
}

.modal-btn-confirm {
  background: var(--gradient-warm);
  color: #fff;
}
