/**
 * 登录页样式 V2.0 — 温暖精致风
 */

.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ═══ Logo 区域 ═══ */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  padding-bottom: 64rpx;
}

.logo-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 48rpx rgba(200, 169, 110, 0.25), 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.logo-img {
  width: 120rpx;
  height: 120rpx;
}

.logo-title {
  margin-top: 28rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 4rpx;
}

/* ═══ 登录按钮区 ═══ */
.login-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 微信快捷登录按钮 */
.wechat-btn {
  width: 100%;
  height: 100rpx;
  background: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wechat-btn:active {
  opacity: 0.9;
  transform: scale(0.99);
}

.wechat-btn-icon {
  font-size: 36rpx;
}

/* 手机号登录按钮 */
.phone-btn {
  width: 100%;
  height: 100rpx;
  margin-top: 24rpx;
  background: var(--bg-card);
  color: var(--color-accent);
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 50rpx;
  border: 2rpx solid var(--color-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.phone-btn:active {
  background: var(--color-accent-light);
  transform: scale(0.99);
}

.phone-btn-icon {
  font-size: 36rpx;
}

/* 协议未勾选 — 按钮置灰 */
.btn-muted {
  opacity: 0.45;
  pointer-events: none;
}

/* ═══ 手机号输入区 — 平滑展开 ═══ */
.phone-section {
  width: 100%;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.35s ease;
}

.phone-section-open {
  max-height: 300rpx;
  opacity: 1;
  margin-top: 24rpx;
}

.phone-input-wrap {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 8rpx 28rpx;
  box-shadow: var(--shadow-sm);
  border: 2rpx solid var(--border-color);
}

.phone-input {
  width: 100%;
  height: 92rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.phone-placeholder {
  color: var(--text-placeholder);
}

.phone-submit-btn {
  width: 100%;
  height: 92rpx;
  margin-top: 20rpx;
  background: var(--gradient-warm);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 46rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(200, 169, 110, 0.3);
}

.phone-submit-btn:active {
  opacity: 0.9;
  transform: scale(0.99);
}

.phone-submit-btn[disabled] {
  opacity: 0.5;
}

/* ═══ 协议勾选 ═══ */
.terms-section {
  width: 100%;
  padding: 48rpx 0 0;
}

.terms-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  flex-wrap: wrap;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  margin-top: 2rpx;
  flex-shrink: 0;
  background: var(--bg-card);
}

.checkbox.checked {
  background: var(--color-accent);
  border-color: var(--color-accent);
}

.check-mark {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

.terms-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 40rpx;
}

.terms-link {
  font-size: 26rpx;
  color: var(--color-accent);
  line-height: 40rpx;
  text-decoration: underline;
  padding: 0 2rpx;
}
