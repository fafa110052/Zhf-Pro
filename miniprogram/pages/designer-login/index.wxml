<!-- 登录页 V2.1 — 温暖精致风 -->
<view class="page">

  <!-- ═══ Logo 区域 ═══ -->
  <view class="logo-area">
    <image class="logo-img" src="/images/zhflogo.png" mode="aspectFill" />
    <text class="logo-title">住好房</text>
  </view>

  <!-- ═══ 登录区 ═══ -->
  <view class="login-actions">
    <!-- 手机号输入框 -->
    <view class="phone-input-wrap {{loading || quickLoginLoading ? 'input-disabled' : ''}}">
      <input
        class="phone-input"
        type="number"
        maxlength="11"
        placeholder="请输入手机号"
        placeholder-class="phone-placeholder"
        value="{{phone}}"
        bindinput="onPhoneInput"
        disabled="{{loading || quickLoginLoading}}"
      />
    </view>

    <!-- 手机号登录 -->
    <button class="phone-btn" bindtap="onLogin" disabled="{{loading || quickLoginLoading}}">手机号登录</button>

    <!-- 微信授权快捷登录 -->
    <button
      class="wechat-btn"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetPhoneNumber"
      loading="{{quickLoginLoading}}"
      disabled="{{quickLoginLoading}}"
    >{{quickLoginLoading ? '加载中...' : '微信授权快捷登录'}}</button>
  </view>

  <!-- ═══ 协议勾选 ═══ -->
  <view class="terms-section {{loading || quickLoginLoading ? 'terms-disabled' : ''}}">
    <view class="terms-row" bindtap="onAgreeToggle">
      <view class="checkbox {{agreeTerms ? 'checked' : ''}}">
        <text wx:if="{{agreeTerms}}" class="check-mark">✓</text>
      </view>
      <text class="terms-text">已阅读并同意</text>
      <text class="terms-link" catchtap="onOpenAgreement">《用户协议》</text>
      <text class="terms-text">和</text>
      <text class="terms-link" catchtap="onOpenPrivacy">《隐私政策》</text>
    </view>
  </view>

  <!-- ═══ 自定义协议弹窗 ═══ -->
  <view wx:if="{{showAgreementModal}}" class="modal-mask" catchtap="onModalCancel">
    <view class="modal-box" catchtap="noop">
      <view class="modal-title">用户协议与隐私政策</view>
      <view class="modal-content">请阅读并同意《用户协议》和《隐私政策》后继续登录</view>
      <view class="modal-btns">
        <view class="modal-btn modal-btn-cancel" bindtap="onModalCancel">暂不同意</view>
        <view class="modal-btn modal-btn-confirm" bindtap="onModalConfirm">同意并继续</view>
      </view>
    </view>
  </view>
</view>
