<!-- 登录页 V2.0 — 温暖精致风 -->
<view class="page">

  <!-- ═══ Logo 区域 ═══ -->
  <view class="logo-area">
    <view class="logo-ring">
      <image class="logo-img" src="/images/zhflogo.png" mode="aspectFit" />
    </view>
    <text class="logo-title">住好房</text>
  </view>

  <!-- ═══ 登录按钮区 ═══ -->
  <view class="login-actions">
    <!-- 微信授权快捷登录 -->
    <button
      class="wechat-btn {{agreeTerms ? '' : 'btn-muted'}}"
      open-type="{{agreeTerms ? 'getPhoneNumber' : ''}}"
      bindgetphonenumber="onGetPhoneNumber"
      loading="{{quickLoginLoading}}"
      disabled="{{!agreeTerms || quickLoginLoading}}"
    >
      <text class="wechat-btn-icon">📱</text>
      <text>{{quickLoginLoading ? '登录中...' : '微信授权快捷登录'}}</text>
    </button>

    <!-- 手机号登录入口 -->
    <view
      class="phone-btn {{agreeTerms ? '' : 'btn-muted'}}"
      bindtap="onTogglePhone"
    >
      <text class="phone-btn-icon">📞</text>
      <text>手机号登录</text>
    </view>

    <!-- 手机号输入区（平滑展开） -->
    <view class="phone-section {{showPhoneInput ? 'phone-section-open' : ''}}">
      <view class="phone-input-wrap">
        <input
          class="phone-input"
          type="number"
          maxlength="11"
          placeholder="请输入手机号"
          placeholder-class="phone-placeholder"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
      <button
        class="phone-submit-btn {{loading ? 'btn-loading' : ''}}"
        bindtap="onLogin"
        disabled="{{loading || !agreeTerms}}"
        loading="{{loading}}"
      >
        {{loading ? '登录中...' : '立即登录'}}
      </button>
    </view>
  </view>

  <!-- ═══ 协议勾选 ═══ -->
  <view class="terms-section">
    <view class="terms-row" bindtap="onAgreeToggle">
      <view class="checkbox {{agreeTerms ? 'checked' : ''}}">
        <text wx:if="{{agreeTerms}}" class="check-mark">✓</text>
      </view>
      <text class="terms-text">已阅读并同意</text>
      <text class="terms-link" catchtap="onOpenAgreement">《用户协议》</text>
      <text class="terms-text">和</text>
      <text class="terms-link" catchtap="onOpenPrivacy">《隐私政策》</text>
    </view>
  </view>
</view>
