/**
 * 作品上传/编辑页样式
 */
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ═══ Loading ═══ */
.page-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
  color: var(--text-tertiary);
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ═══ 图片上传 ═══ */
.image-upload-section {
  margin: 24rpx;
  padding: 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-sm);
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-cell {
  width: 156rpx;
  height: 156rpx;
  border-radius: var(--border-radius-sm);
  overflow: hidden;
  position: relative;
  background: #f1f5f9;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: var(--font-xs);
}

/* 封面标记 */
.cover-badge {
  position: absolute;
  left: 0;
  bottom: 0;
  padding: 4rpx 12rpx;
  background: var(--color-primary);
  border-radius: 0 6rpx 0 0;
}

.cover-badge text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 500;
}

/* 设封面提示 */
.set-cover-hint {
  position: absolute;
  left: 0;
  bottom: 0;
  padding: 4rpx 12rpx;
  background: rgba(0,0,0,0.45);
  border-radius: 0 6rpx 0 0;
}

.set-cover-hint text {
  font-size: 18rpx;
  color: #fff;
  font-weight: 400;
}

.image-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--border-color);
}

.image-add:active {
  background: #f8fafc;
}

.add-icon {
  font-size: 44rpx;
  color: var(--text-placeholder);
  line-height: 1;
}

.add-text {
  font-size: var(--font-xs);
  color: var(--text-placeholder);
  margin-top: 4rpx;
}

.image-hint {
  display: block;
  margin-top: 16rpx;
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  text-align: center;
}

/* ═══ 表单组 ═══ */
.form-section {
  padding: 0 24rpx;
}

.form-group {
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-sm);
}

.group-title {
  display: block;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.required-star {
  color: var(--color-danger);
  font-weight: 700;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f8fafc;
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--color-accent);
  background: #fff;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  padding: 16rpx 20rpx;
  background: #f8fafc;
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: var(--color-accent);
  background: #fff;
}

/* 字数统计 */
.form-counter {
  display: block;
  margin-top: 6rpx;
  font-size: var(--font-xs);
  color: var(--text-placeholder);
  text-align: right;
}

/* Picker 模拟输入框 */
.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f8fafc;
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-base);
}

.picker-placeholder {
  color: var(--text-placeholder);
}

.picker-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.picker-arrow {
  flex-shrink: 0;
  margin-left: 12rpx;
  font-size: var(--font-xs);
  color: var(--text-placeholder);
}

/* 双列 */
.form-row {
  display: flex;
  gap: 16rpx;
}

.form-half {
  flex: 1;
}

/* ═══ 操作按钮 ═══ */
.form-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0 8rpx;
}

.action-btn {
  height: 88rpx;
  border-radius: var(--border-radius-sm);
  font-size: var(--font-md);
  line-height: 88rpx;
  padding: 0;
}

.action-btn::after {
  border: none;
  border-radius: var(--border-radius-sm);
}

/* ═══ 底部提示 ═══ */
.form-notice {
  text-align: center;
  padding: 8rpx 0 40rpx;
}

.form-notice text {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
}
