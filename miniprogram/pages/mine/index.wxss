/**
 * 我的页面样式
 */

.page {
  min-height: 100vh;
  background: #f8fafc;
}

/* ═══ 未登录头部 ═══ */
.guest-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 48rpx;
  background: #fff;
}

.guest-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.guest-avatar-icon {
  font-size: 56rpx;
}

.guest-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.guest-subtitle {
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 28rpx;
}

.guest-login-btn {
  padding: 16rpx 56rpx;
  background: #1e293b;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.guest-login-btn:active {
  opacity: 0.85;
}

/* ═══ 个人信息卡片 ═══ */
.profile-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.profile-row {
  display: flex;
  align-items: center;
}

.profile-avatar-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.profile-avatar-placeholder {
  font-size: 48rpx;
}

.avatar-pending-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: #f59e0b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  border: 2rpx solid #fff;
}

.profile-body {
  flex: 1;
}

.profile-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.profile-phone {
  display: block;
  font-size: 26rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.profile-edit {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: #3b82f6;
  background: #eff6ff;
  border-radius: 20rpx;
}

/* 角色标签 */
.role-badge {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.role-guest {
  color: #64748b;
  background: #f1f5f9;
}

.role-designer {
  color: #3b82f6;
  background: #eff6ff;
}

.role-owner {
  color: #d97706;
  background: #fffbeb;
}

/* 业主楼盘信息 */
.owner-property-info {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #f8fafc;
  border-radius: 14rpx;
}
.owner-property-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.owner-property-row:last-child {
  margin-bottom: 0;
}
.owner-property-label {
  font-size: 24rpx;
  color: #94a3b8;
  width: 120rpx;
  flex-shrink: 0;
}
.owner-property-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #334155;
}

/* 申请设计师入口 */
.apply-designer-bar {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #eff6ff, #f0f9ff);
  border-radius: 14rpx;
  border: 2rpx solid #bfdbfe;
}

.apply-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
}

.apply-text {
  flex: 1;
  font-size: 28rpx;
  color: #2563eb;
  font-weight: 500;
}

.apply-arrow {
  font-size: 28rpx;
  color: #93c5fd;
}

/* 统计网格 */
.stats-grid {
  display: flex;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid #f1f5f9;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.stats-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

/* ═══ 菜单 ═══ */
.menu-section {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.menu-group-title {
  padding: 20rpx 28rpx 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 2rpx solid #f8fafc;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f8fafc;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #0f172a;
}

.menu-label-danger {
  color: #ef4444;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cbd5e1;
  font-weight: 300;
}

/* ═══ 加载中 ═══ */
.page-loading {
  padding: 100rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 28rpx;
}

/* ═══ V1.3 施工角色标签 ═══ */
.role-design-director {
  color: #4338ca;
  background: #eef2ff;
}
.role-engineer {
  color: #0e7490;
  background: #ecfeff;
}
.role-engineering-director {
  color: #15803d;
  background: #f0fdf4;
}

/* ═══ V1.3 菜单待办 badge ═══ */
.menu-badge {
  background: #ef4444;
  color: #fff;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

/* ═══ 安全区 ═══ */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}
