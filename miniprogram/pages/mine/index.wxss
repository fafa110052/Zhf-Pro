/**
 * 我的页面样式 V2.0 — 温暖精致风
 */

.page {
  min-height: 100vh;
  background: var(--bg-page);
}

/* ═══ 未登录头部 ═══ */
.guest-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 48rpx;
  background: var(--bg-card);
}

.guest-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: var(--color-accent-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.guest-avatar-icon {
  font-size: 56rpx;
}

.guest-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.guest-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 28rpx;
}

.guest-login-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  box-sizing: border-box;
  padding: 16rpx 56rpx;
  background: var(--gradient-warm);
  color: #fff;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.guest-login-btn:active {
  opacity: 0.85;
}

/* ═══ 个人信息卡片 ═══ */
.profile-card {
  margin: 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.profile-row {
  display: flex;
  align-items: center;
}

.profile-avatar-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--color-accent-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.profile-avatar-placeholder {
  font-size: 48rpx;
}

.avatar-pending-tag {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  background: var(--color-warning);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  border: 2rpx solid var(--bg-card);
}

.profile-body {
  flex: 1;
}

.profile-name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.profile-phone {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

.profile-edit {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  color: var(--color-accent);
  background: var(--color-accent-light);
  border-radius: 20rpx;
}

/* 角色标签 */
.role-badge {
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 20rpx;
}

.role-guest {
  color: var(--text-secondary);
  background: #f5f0e8;
}

.role-designer {
  position: relative;
  color: var(--color-accent);
  background: var(--color-accent-light);
}

/* 该标签可点击进入设计师中心 — 扩大触控热区至 88rpx（视觉不变） */
.role-designer::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  min-width: 88rpx;
  height: 88rpx;
}

.role-owner {
  color: #b8952a;
  background: #fdf8ec;
}

/* 业主楼盘信息 */
.owner-property-info {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: var(--bg-page);
  border-radius: 14rpx;
}
.owner-property-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.owner-property-row:last-child {
  margin-bottom: 0;
}
.owner-property-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  width: 120rpx;
  flex-shrink: 0;
}
.owner-property-value {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

/* 申请设计师入口 */
.apply-designer-bar {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #fdf8f0, #faf5ed);
  border-radius: 14rpx;
  border: 2rpx solid var(--border-color);
}

.apply-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
}

.apply-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-accent-deep);
  font-weight: 500;
}

.apply-arrow {
  font-size: 28rpx;
  color: var(--color-accent);
}

/* 统计网格 */
.stats-grid {
  display: flex;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid var(--border-color);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.stats-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* ═══ 菜单 ═══ */
.menu-section {
  margin: 0 24rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-group-title {
  padding: 20rpx 28rpx 8rpx;
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 2rpx solid var(--bg-page);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-page);
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
}

.menu-label-danger {
  color: var(--color-danger);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--border-color);
  font-weight: 300;
}

/* ═══ 加载中 ═══ */
.page-loading {
  padding: 100rpx 0;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ═══ V1.3 施工角色标签 ═══ */
.role-design-director {
  color: #6d5c3f;
  background: #f5f0e8;
}
.role-engineer {
  color: #5a7a6a;
  background: #edf5f0;
}
.role-engineering-director {
  color: #6a7a5a;
  background: #f2f6ee;
}

/* ═══ V1.3 菜单待办 badge ═══ */
.menu-badge {
  background: var(--color-danger);
  color: #fff;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

/* ═══ 安全区 ═══ */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}
