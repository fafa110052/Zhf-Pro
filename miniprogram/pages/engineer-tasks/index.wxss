.page{min-height:100vh;background:#f8fafc}
.page-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;background:#f8fafc}
.loading-dot-pulse{display:flex;gap:12rpx}
.dot{width:14rpx;height:14rpx;background:#cbd5e1;border-radius:50%;animation:dotPulse 1.4s ease-in-out infinite both}
.dot:nth-child(1){animation-delay:0s}.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
@keyframes dotPulse{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}
.loading-hint{margin-top:24rpx;font-size:26rpx;color:#94a3b8}
.page-error{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;background:#f8fafc}
.error-icon{font-size:80rpx;margin-bottom:24rpx}.error-msg{font-size:32rpx;font-weight:600;color:#475569;margin-bottom:12rpx}
.error-hint{font-size:24rpx;color:#3b82f6}
.tab-bar{display:flex;background:#fff;border-bottom:1rpx solid #e2e8f0}
.tab-item{flex:1;text-align:center;padding:24rpx 0;font-size:28rpx;color:#64748b;position:relative}
.tab-active{color:#1e293b;font-weight:600}
.tab-active::after{content:'';position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:48rpx;height:4rpx;background:#1e293b;border-radius:2rpx}
.list{padding:20rpx 24rpx}
.project-card{background:#fff;border-radius:16rpx;padding:0;margin-bottom:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);overflow:hidden}
.project-header{display:flex;align-items:center;justify-content:space-between;padding:24rpx 28rpx 18rpx;border-bottom:1rpx solid #f1f5f9}
.project-info{flex:1;min-width:0}
.project-no{font-size:26rpx;font-weight:700;color:#1e293b;display:block}
.project-property{font-size:24rpx;color:#64748b;margin-top:4rpx;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.project-count{font-size:22rpx;color:#94a3b8;background:#f8fafc;padding:6rpx 14rpx;border-radius:12rpx;flex-shrink:0;margin-left:16rpx}
.phase-list{padding:8rpx 0}
.phase-row{display:flex;align-items:center;padding:18rpx 28rpx;border-bottom:1rpx solid #f8fafc}
.phase-row:last-child{border-bottom:none}
.phase-row:active{background:#f8fafc}
.phase-dot{width:12rpx;height:12rpx;border-radius:6rpx;margin-right:14rpx;flex-shrink:0}
.phase-dot.tag-yellow{background:#f59e0b}.phase-dot.tag-green{background:#22c55e}
.phase-dot.tag-red{background:#ef4444}.phase-dot.tag-blue{background:#3b82f6}
.phase-dot.tag-orange{background:#f97316}.phase-dot.tag-gray{background:#94a3b8}
.phase-label{flex:1;font-size:26rpx;color:#334155}
.status-tag{padding:6rpx 18rpx;border-radius:20rpx;font-size:22rpx;margin-left:12rpx;flex-shrink:0}
.tag-yellow{background:#fef3c7;color:#b45309}.tag-green{background:#dcfce7;color:#166534}
.tag-red{background:#fee2e2;color:#991b1b}.tag-blue{background:#dbeafe;color:#1e40af}
.tag-orange{background:#fff7ed;color:#9a3412}.tag-gray{background:#f1f5f9;color:#64748b}
.phase-arrow{font-size:28rpx;color:#cbd5e1;margin-left:10rpx}
.empty-state{display:flex;flex-direction:column;align-items:center;padding:160rpx 48rpx}
.empty-icon{font-size:80rpx;margin-bottom:24rpx}.empty-title{font-size:32rpx;font-weight:600;color:#475569;margin-bottom:12rpx}
.phase-thumb{width:48rpx;height:48rpx;border-radius:8rpx;margin-right:12rpx;flex-shrink:0;background:#f1f5f9}.phase-img-count{font-size:20rpx;color:#94a3b8;margin-right:8rpx;flex-shrink:0}
