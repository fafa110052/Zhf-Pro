.page{min-height:100vh;background:var(--bg-page)}
.page-loading{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;background:var(--bg-page)}
.loading-dot-pulse{display:flex;gap:12rpx}
.dot{width:14rpx;height:14rpx;background:var(--text-tertiary);border-radius:50%;animation:dotPulse 1.4s ease-in-out infinite both}
.dot:nth-child(1){animation-delay:0s}.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
@keyframes dotPulse{0%,80%,100%{transform:scale(0)}40%{transform:scale(1)}}
.loading-hint{margin-top:24rpx;font-size:26rpx;color:var(--text-tertiary)}
.page-error{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;background:var(--bg-page)}
.error-icon{font-size:80rpx;margin-bottom:24rpx}.error-msg{font-size:32rpx;font-weight:600;color:var(--text-secondary);margin-bottom:12rpx}
.error-hint{font-size:24rpx;color:var(--color-accent)}
.list{padding:20rpx 24rpx}
.project-card{background:var(--bg-card);border-radius:16rpx;padding:0;margin-bottom:24rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04);overflow:hidden}
.project-header{display:flex;align-items:center;justify-content:space-between;padding:24rpx 28rpx 18rpx;border-bottom:1rpx solid #f5f0e8}
.project-info{flex:1;min-width:0}
.project-no{font-size:26rpx;font-weight:700;color:var(--text-primary);display:block}
.project-property{font-size:24rpx;color:var(--text-secondary);margin-top:4rpx;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.project-count{font-size:22rpx;color:var(--text-tertiary);background:var(--bg-page);padding:6rpx 14rpx;border-radius:12rpx;flex-shrink:0;margin-left:16rpx}
.phase-list{padding:8rpx 0}
.phase-row{display:flex;align-items:center;padding:18rpx 28rpx;border-bottom:1rpx solid var(--bg-page)}
.phase-row:last-child{border-bottom:none}
.phase-row:active{background:var(--bg-page)}
.phase-dot{width:12rpx;height:12rpx;border-radius:6rpx;margin-right:14rpx;flex-shrink:0}
.phase-dot.tag-yellow{background:#f59e0b}.phase-dot.tag-green{background:#22c55e}
.phase-dot.tag-red{background:#ef4444}.phase-dot.tag-blue{background:var(--color-accent)}
.phase-dot.tag-orange{background:#f97316}.phase-dot.tag-gray{background:var(--text-tertiary)}
.phase-label{flex:1;font-size:26rpx;color:var(--text-secondary)}
.status-tag{padding:6rpx 18rpx;border-radius:20rpx;font-size:22rpx;margin-left:12rpx;flex-shrink:0}
.tag-yellow{background:#fef3c7;color:#b45309}.tag-green{background:#dcfce7;color:#166534}
.tag-red{background:#fee2e2;color:#991b1b}.tag-blue{background:var(--color-accent-light);color:var(--color-accent-deep)}
.tag-orange{background:var(--bg-card)7ed;color:#9a3412}.tag-gray{background:#f5f0e8;color:var(--text-secondary)}
.phase-arrow{font-size:28rpx;color:var(--text-tertiary);margin-left:10rpx}
.empty-state{display:flex;flex-direction:column;align-items:center;padding:160rpx 48rpx}
.empty-icon{font-size:80rpx;margin-bottom:24rpx}.empty-title{font-size:32rpx;font-weight:600;color:var(--text-secondary);margin-bottom:12rpx}
.phase-thumb{width:48rpx;height:48rpx;border-radius:8rpx;margin-right:12rpx;flex-shrink:0;background:#f5f0e8}.phase-img-count{font-size:20rpx;color:var(--text-tertiary);margin-right:8rpx;flex-shrink:0}
