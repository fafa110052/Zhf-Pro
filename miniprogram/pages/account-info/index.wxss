/* 账号信息页 */
.page {
  height: 100vh;
  background: var(--bg-page);
  box-sizing: border-box;
}

.content {
  padding: 48rpx 40rpx 60rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  margin: 20rpx auto 24rpx;
  border-radius: 50%;
  background: var(--bg-card);
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 56rpx;
  color: var(--text-secondary);
}

.page-title {
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.card {
  margin-top: 40rpx;
  padding: 32rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: var(--border-radius-lg);
  box-shadow: var(--shadow-sm);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.info-row + .info-row {
  border-top: 1rpx solid var(--border-color);
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.hint {
  margin: 36rpx 4rpx 0;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-tertiary);
}

.btn-danger {
  margin-top: 56rpx;
  background: var(--color-danger);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
}

.btn-danger::after {
  border: none;
}
