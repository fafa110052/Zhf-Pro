.page { min-height: 100vh; background: var(--bg-page); display: flex; flex-direction: column; align-items: center; padding: 80rpx 32rpx 40rpx; }

/* 结果卡片 */
.result-card { width: 100%; background: var(--bg-card); border-radius: var(--border-radius-xl); padding: 60rpx 40rpx 40rpx; text-align: center; box-shadow: var(--shadow-md); }

.result-icon-wrap { margin-bottom: 32rpx; }
.result-icon { font-size: 120rpx; }

.result-title { font-size: 40rpx; font-weight: 700; color: var(--color-success); display: block; margin-bottom: 16rpx; }
.result-desc { font-size: 28rpx; color: var(--text-secondary); display: block; line-height: 1.6; }

/* 订单信息 */
.order-info { margin-top: 40rpx; background: var(--bg-page); border-radius: var(--border-radius-lg); padding: 24rpx 28rpx; text-align: left; }
.order-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.order-row + .order-row { border-top: 1rpx solid var(--border-color); }
.order-label { font-size: 26rpx; color: var(--text-secondary); }
.order-value { font-size: 26rpx; color: var(--text-primary); }
.order-no { font-weight: 600; letter-spacing: 2rpx; }

.status-tag { padding: 6rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; }
.tag-yellow { background: #fdf8ec; color: #b8952a; }

/* 操作 */
.action-area { width: 100%; margin-top: 48rpx; }
.action-btn { width: 100%; height: 88rpx; border-radius: 44rpx; font-size: 30rpx; font-weight: 500; border: none; margin-bottom: 20rpx; display: flex; align-items: center; justify-content: center; }
.action-btn-primary { background: var(--gradient-warm); color: #fff; }
.action-btn-secondary { background: var(--bg-card); color: var(--color-accent); border: 2rpx solid var(--color-accent); }
.action-btn-ghost { background: transparent; color: var(--text-secondary); }
