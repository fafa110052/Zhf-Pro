.page { min-height: 100vh; background: #f8fafc; display: flex; flex-direction: column; align-items: center; padding: 80rpx 32rpx 40rpx; }

/* 结果卡片 */
.result-card { width: 100%; background: #fff; border-radius: 24rpx; padding: 60rpx 40rpx 40rpx; text-align: center; box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06); }

.result-icon-wrap { margin-bottom: 32rpx; }
.result-icon { font-size: 120rpx; }

.result-title { font-size: 40rpx; font-weight: 700; color: #16a34a; display: block; margin-bottom: 16rpx; }
.result-desc { font-size: 28rpx; color: #64748b; display: block; line-height: 1.6; }

/* 订单信息 */
.order-info { margin-top: 40rpx; background: #f8fafc; border-radius: 16rpx; padding: 24rpx 28rpx; text-align: left; }
.order-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.order-row + .order-row { border-top: 1rpx solid #e2e8f0; }
.order-label { font-size: 26rpx; color: #64748b; }
.order-value { font-size: 26rpx; color: #1e293b; }
.order-no { font-weight: 600; letter-spacing: 2rpx; }

.status-tag { padding: 6rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; }
.tag-yellow { background: #fef3c7; color: #b45309; }

/* 操作 */
.action-area { width: 100%; margin-top: 48rpx; }
.action-btn { width: 100%; height: 88rpx; border-radius: 44rpx; font-size: 30rpx; font-weight: 500; border: none; margin-bottom: 20rpx; display: flex; align-items: center; justify-content: center; }
.action-btn-primary { background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; }
.action-btn-secondary { background: #fff; color: #3b82f6; border: 2rpx solid #3b82f6; }
.action-btn-ghost { background: transparent; color: #64748b; }
