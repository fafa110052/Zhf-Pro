/**
 * 用户协议页样式
 */

.page {
  min-height: 100vh;
  background: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.content {
  padding: 40rpx 36rpx 80rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3d3226;
  text-align: center;
  margin-bottom: 16rpx;
}

.update-date {
  display: block;
  font-size: 24rpx;
  color: #b8a99a;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
  white-space: pre-line;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #3d3226;
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.body-text {
  display: block;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.8;
  margin-bottom: 12rpx;
}
