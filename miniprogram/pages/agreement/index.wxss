/**
 * 用户协议页样式
 */

.page {
  min-height: 100vh;
  background: #fff;
}

.content {
  padding: 40rpx 36rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 16rpx;
}

.update-date {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-top: 32rpx;
  margin-bottom: 16rpx;
}

.body-text {
  display: block;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.bottom-space {
  height: 80rpx;
}
