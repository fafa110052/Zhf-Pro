.page { min-height: 100vh; background: #f8fafc; }

.page-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #f8fafc; }
.loading-dot-pulse { display: flex; gap: 12rpx; }
.dot { width: 14rpx; height: 14rpx; background: #cbd5e1; border-radius: 50%; animation: dotPulse 1.4s ease-in-out infinite both; }
.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse { 0%,80%,100% { transform: scale(0); } 40% { transform: scale(1); } }
.loading-hint { margin-top: 24rpx; font-size: 26rpx; color: #94a3b8; }

.page-error { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #f8fafc; }
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-msg { font-size: 32rpx; font-weight: 600; color: #475569; margin-bottom: 12rpx; }
.error-hint { font-size: 24rpx; color: #3b82f6; }

.list { padding: 20rpx 24rpx; }
.order-card { background: #fff; border-radius: 16rpx; padding: 24rpx 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.order-no { font-size: 26rpx; font-weight: 600; color: #3b82f6; letter-spacing: 2rpx; }
.status-tag { padding: 6rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; }
.tag-yellow { background: #fef3c7; color: #b45309; }
.tag-green  { background: #dcfce7; color: #166534; }
.tag-red    { background: #fee2e2; color: #991b1b; }
.tag-blue   { background: #dbeafe; color: #1e40af; }
.tag-orange { background: #fff7ed; color: #9a3412; }
.card-body { display: flex; flex-direction: column; margin-bottom: 16rpx; }
.property-name { font-size: 30rpx; font-weight: 500; color: #1e293b; }
.room-number { font-size: 26rpx; color: #64748b; margin-top: 6rpx; }
.construction-status-line { margin-top: 8rpx; }
.construction-badge { display: inline-block; padding: 2rpx 12rpx; border-radius: 8rpx; font-size: 22rpx; }
.card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 16rpx; border-top: 1rpx solid #f1f5f9; }
.order-time { font-size: 24rpx; color: #94a3b8; }
.order-arrow { font-size: 26rpx; color: #3b82f6; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 160rpx 48rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: #475569; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #94a3b8; text-align: center; }
