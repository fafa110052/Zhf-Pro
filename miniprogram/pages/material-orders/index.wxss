.page { min-height: 100vh; background: var(--bg-page); }

.page-loading { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: var(--bg-page); }
.loading-dot-pulse { display: flex; gap: 12rpx; }
.dot { width: 14rpx; height: 14rpx; background: var(--text-tertiary); border-radius: 50%; animation: dotPulse 1.4s ease-in-out infinite both; }
.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse { 0%,80%,100% { transform: scale(0); } 40% { transform: scale(1); } }
.loading-hint { margin-top: 24rpx; font-size: 26rpx; color: var(--text-tertiary); }

.page-error { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: var(--bg-page); }
.error-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.error-msg { font-size: 32rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 12rpx; }
.error-hint { font-size: 24rpx; color: var(--color-accent); }

.list { padding: 20rpx 24rpx; }
.order-card { background: var(--bg-card); border-radius: var(--border-radius-lg); padding: 24rpx 28rpx; margin-bottom: 20rpx; box-shadow: var(--shadow-sm); }

/* 卡片头部：信息小卡片 — 带阴影的内嵌卡片，营造层次感 */
.card-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #fefefe 0%, #f8f9fb 100%);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05), 0 1rpx 3rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.04);
}
.property-title { font-size: 32rpx; font-weight: 600; color: var(--text-primary); line-height: 1.4; }
.header-meta { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.order-no { font-size: 24rpx; color: var(--text-tertiary); letter-spacing: 1rpx; }

.status-tag { padding: 6rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; }
.tag-yellow { background: #fdf8ec; color: #b8952a; }
.tag-green  { background: #ecfdf5; color: #166534; }
.tag-red    { background: #fef2f2; color: #991b1b; }
.tag-blue   { background: var(--color-accent-light); color: var(--color-accent); }
.tag-orange { background: #fff7ed; color: #9a3412; }
.card-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 20rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 160rpx 48rpx; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; font-weight: 600; color: var(--text-secondary); margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: var(--text-tertiary); text-align: center; }

/* ==================== 施工进度时间线 ==================== */
.progress-section {
  margin-top: 0;
  padding-top: 0;
}

/* 展开/收缩 切换行 */
.progress-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0;
}
.progress-summary { font-size: 26rpx; color: var(--text-secondary); }
.current-stage { font-weight: 600; color: var(--color-accent); }
.toggle-arrow {
  font-size: 20rpx;
  color: var(--text-tertiary);
  transition: transform 0.3s ease;
}
.toggle-arrow.arrow-up { transform: rotate(180deg); }

/* 可折叠的时间线容器 */
.timeline-wrap {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease;
}
.timeline-wrap.timeline-expanded { max-height: 900rpx; }

.timeline { padding: 12rpx 0 4rpx 8rpx; }

/* 每一步：左节点 + 右信息 */
.timeline-step { display: flex; align-items: flex-start; }
.timeline-step:not(:last-child) { padding-bottom: 6rpx; }

/* 左列：节点 + 竖线 */
.timeline-node-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48rpx;
  flex-shrink: 0;
}

/* 圆点节点 */
.node {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  font-weight: 700;
  flex-shrink: 0;
}
.node.completed { background: var(--color-accent); color: #fff; }
.node.active {
  background: #fff;
  border: 4rpx solid var(--color-accent);
  box-shadow: 0 0 0 4rpx var(--color-accent-light);
}
.node.pending { background: #fff; border: 3rpx solid var(--border-color); }
.node.rejected { background: var(--color-danger); color: #fff; }

/* 竖线连接 */
.line {
  width: 2rpx;
  flex: 1;
  min-height: 24rpx;
  background: var(--border-color);
}
.line.line-done { background: var(--color-accent); }
.line.line-rejected { background: var(--color-danger); opacity: 0.4; }

/* 右列：阶段名称 + 状态文字 */
.timeline-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
  margin-left: 16rpx;
  padding-right: 4rpx;
  min-height: 36rpx;
}
.step-label { font-size: 26rpx; color: var(--text-secondary); }
.step-label.label-active { font-weight: 600; color: var(--text-primary); }
.step-label.label-rejected { color: var(--color-danger); }

.step-state { font-size: 22rpx; color: var(--text-tertiary); }
.step-state.completed { color: var(--color-accent); }
.step-state.active { color: var(--color-accent); font-weight: 500; }
.step-state.rejected { color: var(--color-danger); }
