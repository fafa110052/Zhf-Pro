<!-- 我的选材申请列表 -->
<view class="page">
  <block wx:if="{{ready}}">
    <view wx:if="{{loading}}" class="page-loading">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <view wx:elif="{{error}}" class="page-error" bindtap="onRetry">
      <text class="error-icon zhficon"></text>
      <text class="error-msg">加载失败</text>
      <text class="error-hint">点击重试</text>
    </view>

    <block wx:else>
      <block wx:if="{{orders.length > 0}}">
        <view class="list">
          <view wx:for="{{orders}}" wx:key="order_no" class="order-card"
            data-order-no="{{item.order_no}}" bindtap="onOrderTap">
            <view class="card-header">
              <text class="property-title">{{item.property_name}}<text wx:if="{{item.room_number}}"> · {{item.room_number}}</text></text>
              <view class="header-meta">
                <text class="order-no">{{item.order_no}}</text>
                <view class="status-tag {{item.statusColor}}">
                  <text class="zhficon">{{item.statusIcon}}</text><text> {{item.statusLabel}}</text>
                </view>
              </view>
            </view>

            <!-- 施工进度（仅已开工的显示） -->
            <view wx:if="{{item.hasProgress}}" class="progress-section" catchtap="onToggleTimeline" data-order-no="{{item.order_no}}">
              <view class="progress-toggle">
                <text class="progress-summary">
                  当前：<text class="current-stage">{{item.summaryText}}</text>
                </text>
                <text class="toggle-arrow {{expandedSet[item.order_no] ? 'arrow-up' : ''}}">▼</text>
              </view>
              <view class="timeline-wrap {{expandedSet[item.order_no] ? 'timeline-expanded' : ''}}">
                <view class="timeline">
                  <view wx:for="{{item.timeline}}" wx:for-item="step" wx:key="key" class="timeline-step">
                    <view class="timeline-node-col">
                      <view class="node {{step.state}}">
                        <text wx:if="{{step.state === 'completed'}}">✓</text>
                        <text wx:elif="{{step.state === 'rejected'}}">✗</text>
                      </view>
                      <view wx:if="{{index < item.timeline.length - 1}}" class="line {{step.state === 'completed' ? 'line-done' : ''}} {{step.state === 'rejected' ? 'line-rejected' : ''}}"></view>
                    </view>
                    <view class="timeline-info">
                      <text class="step-label {{step.state === 'active' ? 'label-active' : ''}} {{step.state === 'rejected' ? 'label-rejected' : ''}}">{{step.label}}</text>
                      <text class="step-state {{step.state}}">{{step.stateText}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>

            <view class="card-footer">
              <text class="order-time">{{item.created_at}}</text>
              <text class="order-arrow">查看详情 ›</text>
            </view>
          </view>
        </view>
        <loading-more loading="{{loadingMore}}" hasMore="{{hasMore}}" count="{{orders.length}}"/>
      </block>

      <view wx:if="{{orders.length === 0}}" class="empty-state">
        <text class="empty-icon zhficon"></text>
        <text class="empty-title">暂无申请记录</text>
        <text class="empty-desc">快去选择楼盘开始选材吧</text>
      </view>
    </block>
  </block>
</view>
