.page { min-height: 100vh; background: #f8fafc; padding-bottom: 60rpx; }

/* 顶部 */
.header { background: linear-gradient(135deg, #3b82f6, #2563eb); padding: 40rpx 32rpx; }
.header-title { font-size: 38rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 8rpx; }
.header-sub { font-size: 26rpx; color: rgba(255,255,255,0.7); }

/* 区块 */
.section { margin: 24rpx 24rpx 0; background: #fff; border-radius: 16rpx; padding: 28rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.section-title { font-size: 30rpx; font-weight: 600; color: #1e293b; margin-bottom: 20rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid #f1f5f9; }

/* 材料清单项 */
.summary-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f8fafc; }
.summary-item:last-child { border-bottom: none; }
.summary-name { flex: 1; font-size: 28rpx; color: #1e293b; }
.summary-brand { font-size: 24rpx; color: #64748b; margin: 0 20rpx; }
.summary-price { font-size: 28rpx; font-weight: 600; color: #ef4444; white-space: nowrap; }

/* 表单 */
.form-group { margin-top: 24rpx; }
.form-label { font-size: 28rpx; color: #475569; display: block; margin-bottom: 12rpx; }
.required { color: #ef4444; margin-left: 4rpx; }
.form-input { width: 100%; height: 80rpx; background: #f8fafc; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: #1e293b; box-sizing: border-box; }
.form-textarea { width: 100%; min-height: 140rpx; background: #f8fafc; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #1e293b; box-sizing: border-box; }

/* 提交 */
.submit-area { margin: 48rpx 24rpx 0; text-align: center; }
.submit-btn { width: 100%; height: 96rpx; background: linear-gradient(135deg, #3b82f6, #2563eb); border-radius: 48rpx; font-size: 34rpx; font-weight: 600; color: #fff; border: none; display: flex; align-items: center; justify-content: center; }
.btn-disabled { opacity: 0.6; }
.submit-hint { font-size: 24rpx; color: #94a3b8; margin-top: 20rpx; display: block; }

/* 房号锁定 */
.form-input-locked { width: 100%; height: 80rpx; background: #f1f5f9; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: #94a3b8; box-sizing: border-box; }
.form-hint { font-size: 22rpx; color: #94a3b8; margin-top: 8rpx; display: block; }
