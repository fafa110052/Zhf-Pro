.page { min-height: 100vh; background: var(--bg-page); padding-bottom: 60rpx; }

/* 顶部 */
.header { background: var(--gradient-warm); padding: 40rpx 32rpx; }
.header-title { font-size: 38rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 8rpx; }
.header-sub { font-size: 26rpx; color: rgba(255,255,255,0.7); }

/* 区块 */
.section { margin: 24rpx 24rpx 0; background: var(--bg-card); border-radius: var(--border-radius-lg); padding: 28rpx; box-shadow: var(--shadow-sm); }
.section-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); margin-bottom: 20rpx; padding-bottom: 16rpx; border-bottom: 1rpx solid var(--border-color); }

/* 材料清单项 */
.summary-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid var(--bg-page); }
.summary-item:last-child { border-bottom: none; }
.summary-name { flex: 1; font-size: 28rpx; color: var(--text-primary); }
.summary-brand { font-size: 24rpx; color: var(--text-secondary); margin: 0 20rpx; }
.summary-price { font-size: 28rpx; font-weight: 600; color: var(--color-danger); white-space: nowrap; }

/* 表单 */
.form-group { margin-top: 24rpx; }
.form-label { font-size: 28rpx; color: var(--text-secondary); display: block; margin-bottom: 12rpx; }
.required { color: var(--color-danger); margin-left: 4rpx; }
.form-input { width: 100%; height: 80rpx; background: var(--bg-page); border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box; }
.form-textarea { width: 100%; min-height: 140rpx; background: var(--bg-page); border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: var(--text-primary); box-sizing: border-box; }

/* 提交 */
.submit-area { margin: 48rpx 24rpx 0; text-align: center; }
.submit-btn { width: 100%; height: 96rpx; background: var(--gradient-warm); border-radius: 48rpx; font-size: 34rpx; font-weight: 600; color: #fff; border: none; display: flex; align-items: center; justify-content: center; }
.btn-disabled { opacity: 0.6; }
.submit-hint { font-size: 24rpx; color: var(--text-tertiary); margin-top: 20rpx; display: block; }

/* 房号锁定 */
.form-input-locked { width: 100%; height: 80rpx; background: #f5f0e8; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx; color: var(--text-tertiary); box-sizing: border-box; }
.form-hint { font-size: 22rpx; color: var(--text-tertiary); margin-top: 8rpx; display: block; }
