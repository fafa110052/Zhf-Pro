<!-- 设计师待处理列表 -->
<view class="page">
  <block wx:if="{{ready}}">
    <view wx:if="{{loading}}" class="page-loading">
      <view class="loading-dot-pulse"><view class="dot"></view><view class="dot"></view><view class="dot"></view></view>
      <text class="loading-hint">加载中...</text>
    </view>
    <view wx:elif="{{error}}" class="page-error" bindtap="onRetry">
      <text class="error-icon">⚠️</text>
      <text class="error-msg">加载失败</text>
      <text class="error-hint">点击重试</text>
    </view>
    <block wx:else>
      <block wx:if="{{list.length > 0}}">
        <view class="list">
          <view wx:for="{{list}}" wx:key="id" class="order-card" data-id="{{item.id}}" bindtap="onTapItem">
            <view class="card-header">
              <text class="order-no">阶段{{item.phase_order}} · {{item.phaseLabel}}</text>
              <view class="status-tag {{item.statusColor}}"><text>{{item.statusLabel}}</text></view>
            </view>
            <view class="card-body">
              <text class="property-name">{{item.property_name || '—'}}</text>
              <text class="room-number">{{item.room_number || ''}}</text>
            </view>
            <view class="card-footer">
              <text class="order-time">{{item.updated_at || ''}}</text>
              <text class="order-arrow">处理 ›</text>
            </view>
          </view>
        </view>
      </block>
      <view wx:if="{{list.length === 0}}" class="empty-state">
        <text class="empty-icon">📐</text>
        <text class="empty-title">暂无待处理任务</text>
        <text class="empty-desc">管理员派单后这里会出现任务</text>
      </view>
    </block>
  </block>
</view>
