<!-- 设计师待处理列表 -->
<view class="page">
  <view wx:if="{{!ready}}" class="page-loading">
    <view class="loading-dot-pulse"><view class="dot"></view><view class="dot"></view><view class="dot"></view></view>
    <text class="loading-hint">加载中...</text>
  </view>
  <block wx:if="{{ready}}">
    <view wx:if="{{error}}" class="page-error" bindtap="onRetry">
      <text class="error-icon zhficon"></text>
      <text class="error-msg">加载失败</text>
      <text class="error-hint">点击重试</text>
    </view>
    <block wx:else>
      <block wx:if="{{projects.length > 0}}">
        <view class="list">
          <view wx:for="{{projects}}" wx:key="orderNo" class="project-card">
            <!-- 项目头部 -->
            <view class="project-header">
              <view class="project-info">
                <text class="project-no">{{item.orderNo}}</text>
                <text class="project-property">{{item.propertyName}}{{item.roomNumber ? ' · ' + item.roomNumber : ''}}</text>
              </view>
              <text class="project-count">{{item.phases.length}}个阶段</text>
            </view>
            <!-- 阶段列表 -->
            <view class="phase-list">
              <view wx:for="{{item.phases}}" wx:for-item="phase" wx:key="id"
                class="phase-row" data-id="{{phase.id}}" bindtap="onTapItem">
                <view class="phase-dot {{phase.needsAction ? 'dot-red' : phase.statusColor}}"></view>
                <text class="phase-label">阶段{{phase.phase_order}} · {{phase.phaseLabel}}</text>
                <view class="status-tag {{phase.statusColor}}"><text>{{phase.statusLabel}}</text></view>
                <text class="phase-arrow">›</text>
              </view>
            </view>
          </view>
        </view>
      </block>
      <view wx:if="{{projects.length === 0}}" class="empty-state">
        <text class="empty-icon zhficon">{{mode === 'all' ? '' : ''}}</text>
        <text class="empty-title">{{mode === 'all' ? '暂无项目' : '暂无待处理任务'}}</text>
        <text class="empty-desc" wx:if="{{mode === 'active'}}">管理员派单后这里会出现任务</text>
      </view>
    </block>
  </block>
</view>
