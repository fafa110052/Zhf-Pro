/**
 * 作品详情页样式
 */

.page {
  min-height: 100vh;
  background: #f5f0e8;
  padding-bottom: 40rpx;
}

/* ═══ Loading（全屏居中）═══ */
.page-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f5f0e8;
}

.loading-dot-pulse {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  background: var(--text-tertiary);
  border-radius: 50%;
  animation: pulse 1.2s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-hint {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ═══ 内容淡入动画（掩盖页面过渡时的闪烁）═══ */
.image-section,
.info-card,
.designer-card {
  animation: detailFadeIn 0.35s ease-out both;
}

.info-card { animation-delay: 0.1s; }
.designer-card { animation-delay: 0.2s; }

@keyframes detailFadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ═══ 图片轮播 ═══ */
.image-section {
  position: relative;
  background: var(--text-primary);
}

.image-swiper {
  height: 640rpx;
}

/* 图片容器 — 用于叠加加载状态 */
.swiper-image-wrap {
  width: 100%;
  height: 100%;
  position: relative;
  background: #1e293b;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* ═══ 图片加载进度指示器 ═══ */
.image-loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #1e293b;
}

/* 进度条容器 */
.image-loading-bar {
  width: 240rpx;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

/* 进度条 — 滑动动画 */
.image-loading-bar-track {
  width: 40%;
  height: 100%;
  background: rgba(255, 255, 255, 0.45);
  border-radius: 3rpx;
  animation: image-progress-slide 1.4s ease-in-out infinite;
}

@keyframes image-progress-slide {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(350%);
  }
}

.image-loading-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
}

/* ═══ 图片加载失败 ═══ */
.image-error-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #1e293b;
}

.image-error-icon {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.image-error-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.45);
}

/* 无图片占位 */
.no-image {
  height: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--text-primary);
}

.no-image-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.no-image-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 图片计数器 */
.image-counter {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  padding: 6rpx 18rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #fff;
  backdrop-filter: blur(8rpx);
}

/* 点击预览提示 */
.preview-hint {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  padding: 6rpx 16rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 20rpx;
}

.preview-hint-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ═══ 作品信息卡片 ═══ */
.info-card {
  margin: 20rpx 24rpx;
  padding: 28rpx;
}

.work-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
}

.work-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

/* 数据项网格 */
.meta-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid var(--border-color);
}

.meta-item {
  width: 50%;
  margin-bottom: 24rpx;
}

.meta-item:nth-child(3),
.meta-item:nth-child(4) {
  margin-bottom: 0;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 6rpx;
}

.meta-value {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 设计说明 */
.desc-section {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid var(--border-color);
}

.desc-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.desc-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.75;
  white-space: pre-wrap;
}

/* ═══ 设计师名片 ═══ */
.designer-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
}

.section-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-bottom: 20rpx;
}

.designer-row {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  overflow: hidden;
  background: #f5f0e8;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 2rpx solid var(--border-color);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 44rpx;
}

.designer-body {
  flex: 1;
}

.designer-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.designer-meta {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

.designer-bio {
  display: block;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid var(--border-color);
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

/* ═══ 底部安全区 ═══ */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}
