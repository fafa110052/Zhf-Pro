/**
 * 作品详情页样式
 */

.page {
  min-height: 100vh;
  background: #f1f5f9;
  padding-bottom: 40rpx;
}

/* ═══ Loading（全屏居中）═══ */
.page-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f1f5f9;
}

.loading-dot-pulse {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  background: #cbd5e1;
  border-radius: 50%;
  animation: pulse 1.2s ease-in-out infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes pulse {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-hint {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #94a3b8;
}

/* ═══ 内容淡入动画（掩盖页面过渡时的闪烁）═══ */
.image-section,
.info-card,
.designer-card {
  animation: detailFadeIn 0.35s ease-out both;
}

.info-card { animation-delay: 0.1s; }
.designer-card { animation-delay: 0.2s; }

@keyframes detailFadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ═══ 图片轮播 ═══ */
.image-section {
  position: relative;
  background: #0f172a;
}

.image-swiper {
  height: 640rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 无图片占位 */
.no-image {
  height: 500rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #1e293b;
}

.no-image-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.no-image-text {
  font-size: 28rpx;
  color: #94a3b8;
}

/* 返回按钮（悬浮在图片上） */
.back-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  backdrop-filter: blur(12rpx);
}

.back-btn:active {
  background: rgba(0, 0, 0, 0.55);
}

.back-icon {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
  font-weight: 300;
  margin-top: -4rpx;
}

/* 图片计数器 */
.image-counter {
  position: absolute;
  bottom: 24rpx;
  right: 24rpx;
  padding: 6rpx 18rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #fff;
  backdrop-filter: blur(8rpx);
}

/* 点击预览提示 */
.preview-hint {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  padding: 6rpx 16rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: 20rpx;
}

.preview-hint-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ═══ 作品信息卡片 ═══ */
.info-card {
  margin: 20rpx 24rpx;
  padding: 28rpx;
}

.work-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

.work-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

/* 数据项网格 */
.meta-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid #e2e8f0;
}

.meta-item {
  width: 50%;
  margin-bottom: 24rpx;
}

.meta-item:nth-child(3),
.meta-item:nth-child(4) {
  margin-bottom: 0;
}

.meta-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 6rpx;
}

.meta-value {
  display: block;
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 500;
}

/* 设计说明 */
.desc-section {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid #e2e8f0;
}

.desc-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 14rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.75;
  white-space: pre-wrap;
}

/* ═══ 设计师名片 ═══ */
.designer-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
}

.section-label {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 20rpx;
}

.designer-row {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  overflow: hidden;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  border: 2rpx solid #e2e8f0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 44rpx;
}

.designer-body {
  flex: 1;
}

.designer-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.designer-meta {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.designer-bio {
  display: block;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #e2e8f0;
  font-size: 26rpx;
  color: #64748b;
  line-height: 1.7;
}

/* ═══ 底部安全区 ═══ */
.safe-bottom {
  height: env(safe-area-inset-bottom);
}
