<!-- 风格选择 — 杂志画册式 -->
<view class="page">
  <block wx:if="{{ready}}">
    <!-- Error -->
    <view wx:if="{{error}}" class="page-error">
      <text class="error-msg">加载失败</text>
      <view class="retry-btn" bindtap="onRetry">
        <text>重新加载</text>
      </view>
    </view>

    <block wx:else>
      <!-- 卡片式页眉（居中） -->
      <view class="editorial-header">
        <view class="header-card">
          <text class="header-title">选择你的装修风格</text>
          <view class="header-divider"></view>
          <text class="header-subtitle">CHOOSE YOUR STYLE</text>
        </view>
      </view>

      <!-- 风格卡片列表：图片卡 + 错位文字小卡片，点击直接进入向导 -->
      <view wx:if="{{styles.length > 0}}" class="style-list">
        <view
          wx:for="{{styles}}"
          wx:key="id"
          class="style-item {{index % 2 === 1 ? 'is-even' : ''}}"
          style="animation-delay: {{index * 60}}ms;"
          data-id="{{item.id}}"
          bindtap="onTapStyle"
        >
          <view class="card-image-wrap">
            <image class="card-image" src="{{item.cover_image}}" mode="aspectFill" lazy-load />
          </view>
          <!-- 错位文字小卡片 -->
          <view class="info-chip">
            <view class="chip-text">
              <text class="card-name">{{item.name}}</text>
              <text wx:if="{{item.description}}" class="card-desc">{{item.description}}</text>
            </view>
            <view class="chip-arrow"></view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{styles.length === 0}}" class="empty-state">
        <text class="empty-title">风格准备中，敬请期待</text>
      </view>
    </block>
  </block>
</view>
