<!-- 风格选择 — 杂志画册式 -->
<view class="page">
  <block wx:if="{{ready}}">
    <!-- Error -->
    <view wx:if="{{error}}" class="page-error">
      <text class="error-msg">加载失败</text>
      <view class="retry-btn" bindtap="onRetry">
        <text>重新加载</text>
      </view>
    </view>

    <block wx:else>
      <!-- 画册式页眉 -->
      <view class="editorial-header">
        <view class="header-bar"></view>
        <text class="header-title">选择你的装修风格</text>
        <text class="header-subtitle">CHOOSE YOUR STYLE</text>
      </view>

      <!-- 风格卡片列表 -->
      <view wx:if="{{styles.length > 0}}" class="style-list">
        <view
          wx:for="{{styles}}"
          wx:key="id"
          class="style-card {{item.id === selectedId ? 'is-selected' : ''}}"
          data-id="{{item.id}}"
          bindtap="onSelectStyle"
        >
          <image class="card-image" src="{{item.cover_image}}" mode="aspectFill" lazy-load />
          <!-- 底部渐变叠底 -->
          <view class="card-gradient"></view>
          <!-- 文字信息 -->
          <view class="card-info">
            <text class="card-name">{{item.name}}</text>
            <text wx:if="{{item.description}}" class="card-desc">{{item.description}}</text>
          </view>
          <!-- 选中标记 -->
          <image
            wx:if="{{item.id === selectedId}}"
            class="selected-badge"
            src="/assets/icons/selected-mark.svg"
            mode="aspectFit"
          />
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{styles.length === 0}}" class="empty-state">
        <text class="empty-title">风格准备中，敬请期待</text>
      </view>

      <!-- 底部固定操作栏 -->
      <view wx:if="{{selectedId}}" class="bottom-bar">
        <view class="start-btn" bindtap="onStartWizard">
          <text>开始选材</text>
        </view>
      </view>
    </block>
  </block>
</view>
