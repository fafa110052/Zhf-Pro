<!-- 风格选择 — 杂志画册式 -->
<view class="page">
  <block wx:if="{{ready}}">
    <!-- Error -->
    <view wx:if="{{error}}" class="page-error">
      <text class="error-msg">加载失败</text>
      <view class="retry-btn" bindtap="onRetry">
        <text>重新加载</text>
      </view>
    </view>

    <block wx:else>
      <!-- 卡片式页眉（居中，支持后台配置背景图与文字） -->
      <view class="editorial-header">
        <view class="header-card {{header.image_url ? 'has-image' : ''}}">
          <image wx:if="{{header.image_url}}" class="header-bg" src="{{header.image_url}}" mode="aspectFill" />
          <view wx:if="{{header.image_url}}" class="header-scrim"></view>
          <view class="header-content">
            <text class="header-title">{{header.title}}</text>
            <view class="header-divider"></view>
            <text class="header-subtitle">{{header.subtitle}}</text>
          </view>
        </view>
      </view>

      <!-- 风格卡片列表：图文一体杂志卡，点击直接进入向导 -->
      <view wx:if="{{styles.length > 0}}" class="style-list">
        <view
          wx:for="{{styles}}"
          wx:key="id"
          class="style-item"
          style="animation-delay: {{index * 60}}ms;"
          data-id="{{item.id}}"
          bindtap="onTapStyle"
        >
          <image class="card-image" src="{{item.cover_image}}" mode="aspectFill" lazy-load />
          <!-- 错位悬浮文字卡：左右内收 + 上叠图片下缘 -->
          <view class="card-band">
            <view class="band-text">
              <text class="card-name">{{item.name}}</text>
              <text wx:if="{{item.description}}" class="card-desc">{{item.description}}</text>
            </view>
            <view wx:if="{{item.vr_url}}" class="band-vr" data-url="{{item.vr_url}}" catchtap="onTapVR">
              <view class="vr-icon"></view>
              <text class="vr-text">VR</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{styles.length === 0}}" class="empty-state">
        <text class="empty-title">风格准备中，敬请期待</text>
      </view>
    </block>
  </block>
</view>
