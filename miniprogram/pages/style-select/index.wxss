/**
 * 风格选择页样式 — 杂志画册式（暖白奢华）
 * 标题色 #3D3226（深棕，与 tabBar 选中色呼应，对比度 ~12:1）
 */
.page {
  min-height: 100vh;
  background: #FAF8F5;
  padding-bottom: 48rpx;
}

/* ─── 卡片式页眉（居中） ─── */
.editorial-header {
  padding: 32rpx 32rpx 16rpx;
}

.header-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 44rpx 32rpx 40rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(61, 50, 38, 0.06);
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #3D3226;
  line-height: 1.4;
}

.header-divider {
  width: 56rpx;
  height: 4rpx;
  background: #C9A96E;
  border-radius: 2rpx;
  margin: 18rpx auto 14rpx;
}

.header-subtitle {
  display: block;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: #8C6F47;
}

/* ─── 风格卡片列表 ─── */
.style-list {
  padding: 24rpx 24rpx 0;
}

/* 单项 = 图片卡 + 错位文字小卡片；级联入场 */
.style-item {
  margin-bottom: 44rpx;
  transition: transform 0.2s ease;
  animation: item-in 0.45s ease-out both;
}

.style-item:active {
  transform: scale(0.985);
}

@keyframes item-in {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-image-wrap {
  width: 100%;
  height: 440rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f5f0e8;
  box-shadow: 0 8rpx 28rpx rgba(61, 50, 38, 0.10);
}

.card-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 错位文字小卡片：叠压图片下缘，左右交替 */
.info-chip {
  position: relative;
  margin-top: -56rpx;
  margin-left: 24rpx;
  width: 78%;
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-left: 6rpx solid #C9A96E;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(61, 50, 38, 0.12);
}

.style-item.is-even .info-chip {
  margin-left: auto;
  margin-right: 24rpx;
}

.chip-text {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #3D3226;
}

.card-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* CSS 绘制的金色箭头（免图标资源） */
.chip-arrow {
  flex-shrink: 0;
  width: 18rpx;
  height: 18rpx;
  margin-left: 20rpx;
  border-top: 4rpx solid #C9A96E;
  border-right: 4rpx solid #C9A96E;
  transform: rotate(45deg);
}

/* ─── 空状态 ─── */
.empty-state {
  padding: 160rpx 32rpx;
  text-align: center;
}

.empty-title {
  font-size: 28rpx;
  color: #6B7280;
}

/* ─── 错误状态 ─── */
.page-error {
  padding: 200rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.error-msg {
  font-size: 28rpx;
  color: #6B7280;
}

.retry-btn {
  padding: 16rpx 64rpx;
  border: 2rpx solid #C9A96E;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #C9A96E;
}
