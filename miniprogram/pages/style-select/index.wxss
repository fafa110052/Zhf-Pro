/**
 * 风格选择页样式 — 杂志画册式（暖白奢华）
 * 标题色 #3D3226（深棕，与 tabBar 选中色呼应，对比度 ~12:1）
 */
.page {
  min-height: 100vh;
  background: #FAF8F5;
  padding-bottom: 48rpx;
}

/* ─── 卡片式页眉（居中，支持背景图） ─── */
.editorial-header {
  padding: 32rpx 32rpx 16rpx;
}

.header-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(61, 50, 38, 0.06);
}

.header-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

/* 背景图上的暗色渐变，保证文字可读 */
.header-scrim {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(30, 24, 16, 0.30), rgba(30, 24, 16, 0.55));
}

.header-content {
  position: relative;
  padding: 44rpx 32rpx 40rpx;
}

.header-card.has-image .header-content {
  padding: 56rpx 32rpx 52rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #3D3226;
  line-height: 1.4;
}

.header-card.has-image .header-title {
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.header-divider {
  width: 56rpx;
  height: 4rpx;
  background: #C9A96E;
  border-radius: 2rpx;
  margin: 18rpx auto 14rpx;
}

.header-subtitle {
  display: block;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: #8C6F47;
}

.header-card.has-image .header-subtitle {
  color: rgba(255, 255, 255, 0.85);
}

/* ─── 风格卡片列表 ─── */
.style-list {
  padding: 24rpx 24rpx 0;
}

/* 杂志式错位卡：图片卡 + 悬浮文字卡；级联入场 */
.style-item {
  margin-bottom: 44rpx;
  transition: transform 0.2s ease;
  animation: item-in 0.45s ease-out both;
}

.style-item:active {
  transform: scale(0.985);
}

@keyframes item-in {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-image {
  width: 100%;
  height: 440rpx;
  display: block;
  border-radius: 20rpx;
  background: #f5f0e8;
  box-shadow: 0 8rpx 28rpx rgba(61, 50, 38, 0.10);
}

/* 错位悬浮文字卡：左右内收 24rpx，上叠图片下缘 44rpx */
.card-band {
  position: relative;
  display: flex;
  align-items: center;
  margin: -44rpx 24rpx 0;
  padding: 24rpx 24rpx 24rpx 28rpx;
  background: #FFFFFF;
  border-left: 6rpx solid #C9A96E;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(61, 50, 38, 0.12);
}

.band-text {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #3D3226;
}

.card-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* VR 看房圆形按钮：与作品详情页 VR 悬浮钮同视觉语言（紫渐变） */
.band-vr {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin-left: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B5CF6, #6366F1);
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.35);
}

.band-vr:active {
  opacity: 0.85;
}

/* CSS 绘制的 VR 眼镜简笔图标 */
.vr-icon {
  width: 26rpx;
  height: 16rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 8rpx;
  margin-bottom: 4rpx;
  position: relative;
}

.vr-icon::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -3rpx;
  width: 8rpx;
  height: 6rpx;
  transform: translateX(-50%);
  background: #FFFFFF;
  border-radius: 4rpx 4rpx 0 0;
}

.vr-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1;
}

/* ─── 空状态 ─── */
.empty-state {
  padding: 160rpx 32rpx;
  text-align: center;
}

.empty-title {
  font-size: 28rpx;
  color: #6B7280;
}

/* ─── 错误状态 ─── */
.page-error {
  padding: 200rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.error-msg {
  font-size: 28rpx;
  color: #6B7280;
}

.retry-btn {
  padding: 16rpx 64rpx;
  border: 2rpx solid #C9A96E;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #C9A96E;
}
