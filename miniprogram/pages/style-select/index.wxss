/**
 * 风格选择页样式 — 杂志画册式（暖白奢华）
 * 标题色 #3D3226（深棕，与 tabBar 选中色呼应，对比度 ~12:1）
 */
.page {
  min-height: 100vh;
  background: #FAF8F5;
  padding-bottom: 48rpx;
}

/* ─── 卡片式页眉（居中，支持背景图） ─── */
.editorial-header {
  padding: 32rpx 32rpx 16rpx;
}

.header-card {
  position: relative;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(61, 50, 38, 0.06);
}

.header-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

/* 背景图上的暗色渐变，保证文字可读 */
.header-scrim {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(30, 24, 16, 0.30), rgba(30, 24, 16, 0.55));
}

.header-content {
  position: relative;
  padding: 44rpx 32rpx 40rpx;
}

.header-card.has-image .header-content {
  padding: 56rpx 32rpx 52rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #3D3226;
  line-height: 1.4;
}

.header-card.has-image .header-title {
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.header-divider {
  width: 56rpx;
  height: 4rpx;
  background: #C9A96E;
  border-radius: 2rpx;
  margin: 18rpx auto 14rpx;
}

.header-subtitle {
  display: block;
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: #8C6F47;
}

.header-card.has-image .header-subtitle {
  color: rgba(255, 255, 255, 0.85);
}

/* ─── 风格卡片列表 ─── */
.style-list {
  padding: 24rpx 24rpx 0;
}

/* 图文一体杂志卡：图片 + 贴合下缘的文字区；级联入场 */
.style-item {
  margin-bottom: 40rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(61, 50, 38, 0.10);
  transition: transform 0.2s ease;
  animation: item-in 0.45s ease-out both;
}

.style-item:active {
  transform: scale(0.985);
}

@keyframes item-in {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card-image {
  width: 100%;
  height: 420rpx;
  display: block;
  background: #f5f0e8;
}

/* 贴合图片下缘的文字区（杂志式） */
.card-band {
  display: flex;
  align-items: center;
  padding: 26rpx 28rpx;
  border-left: 6rpx solid #C9A96E;
}

.band-text {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #3D3226;
}

.card-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* CSS 绘制的金色箭头（免图标资源） */
.band-arrow {
  flex-shrink: 0;
  width: 18rpx;
  height: 18rpx;
  margin-left: 20rpx;
  border-top: 4rpx solid #C9A96E;
  border-right: 4rpx solid #C9A96E;
  transform: rotate(45deg);
}

/* ─── 空状态 ─── */
.empty-state {
  padding: 160rpx 32rpx;
  text-align: center;
}

.empty-title {
  font-size: 28rpx;
  color: #6B7280;
}

/* ─── 错误状态 ─── */
.page-error {
  padding: 200rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.error-msg {
  font-size: 28rpx;
  color: #6B7280;
}

.retry-btn {
  padding: 16rpx 64rpx;
  border: 2rpx solid #C9A96E;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #C9A96E;
}
