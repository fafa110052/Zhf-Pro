/**
 * 风格选择页样式 — 杂志画册式（暖白奢华）
 */
.page {
  min-height: 100vh;
  background: #FAF8F5;
  padding-bottom: 160rpx;
}

/* ─── 画册式页眉 ─── */
.editorial-header {
  padding: 24rpx 32rpx 32rpx;
}

.header-bar {
  height: 8rpx;
  background: #1A1A1A;
  border-top: 2rpx solid #C9A96E;
  border-bottom: 2rpx solid #C9A96E;
  margin-bottom: 32rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.4;
}

.header-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: #9CA3AF;
}

/* ─── 风格卡片列表 ─── */
.style-list {
  padding: 0 24rpx;
}

.style-card {
  position: relative;
  width: 100%;
  height: 480rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 3rpx solid transparent;
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  background: #ffffff;
}

/* 翻画册层叠感：后续卡片轻微上叠 */
.style-card + .style-card {
  margin-top: -16rpx;
}

.style-card.is-selected {
  border-color: #C9A96E;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 32rpx rgba(201, 169, 110, 0.35);
  z-index: 1;
}

.card-image {
  width: 100%;
  height: 100%;
  display: block;
  background: #f5f0e8;
}

/* 底部渐变叠底：透明 → 米白 */
.card-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, rgba(250, 248, 245, 0), #FAF8F5);
}

.card-info {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 24rpx;
}

.card-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.card-desc {
  display: block;
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #6B7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 选中标记 */
.selected-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 48rpx;
  height: 48rpx;
}

/* ─── 空状态 ─── */
.empty-state {
  padding: 160rpx 32rpx;
  text-align: center;
}

.empty-title {
  font-size: 28rpx;
  color: #6B7280;
}

/* ─── 错误状态 ─── */
.page-error {
  padding: 200rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.error-msg {
  font-size: 28rpx;
  color: #6B7280;
}

.retry-btn {
  padding: 16rpx 64rpx;
  border: 2rpx solid #C9A96E;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #C9A96E;
}

/* ─── 底部固定操作栏 ─── */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(250, 248, 245, 0.95);
  z-index: 10;
}

.start-btn {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #C9A96E, #B8944E);
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(201, 169, 110, 0.4);
}

.start-btn:active {
  opacity: 0.85;
}
