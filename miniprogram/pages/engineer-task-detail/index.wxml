<view class="page">
  <block wx:if="{{ready}}">
    <view wx:if="{{loading}}" class="page-loading">
      <view class="loading-dot-pulse"><view class="dot"></view><view class="dot"></view><view class="dot"></view></view>
      <text class="loading-hint">加载中...</text>
    </view>
    <view wx:elif="{{error}}" class="page-error" bindtap="onRetry">
      <text class="error-icon zhficon"></text><text class="error-msg">加载失败</text><text class="error-hint">点击重试</text>
    </view>
    <block wx:elif="{{phase}}">
      <view class="status-header">
        <view class="status-tag {{PHASE_STATUS_MAP[phase.status].colorClass}}">
          <text>{{PHASE_STATUS_MAP[phase.status].label}}</text>
        </view>
        <text class="order-no">阶段{{phase.phase_order}} · {{PHASE_TYPE_MAP[phase.phase_type].label}}</text>
      </view>

      <!-- 项目进度 -->
      <view wx:if="{{phase.progress && phase.progress.length > 0}}" class="progress-section">
        <view class="section-title"><text>项目进度</text></view>
        <view class="progress-bar">
          <block wx:for="{{phase.progress}}" wx:key="phase_order">
            <view class="progress-step">
              <view class="progress-dot {{item.dotClass}}">
                <view wx:if="{{item.isCurrent}}" class="progress-dot-inner"></view>
              </view>
              <text class="progress-label {{item.isCurrent ? 'active' : ''}}">{{item.label}}</text>
              <text class="progress-status-text">{{item.statusLabel}}</text>
            </view>
            <view wx:if="{{index < phase.progress.length - 1}}" class="progress-line {{item.lineClass}}"></view>
          </block>
        </view>
      </view>

      <!-- 驳回原因 -->
      <view wx:if="{{phase.engineering_director_reject_reason}}" class="reject-box">
        <text class="reject-label">工程总监驳回原因</text>
        <text class="reject-text">{{phase.engineering_director_reject_reason}}</text>
      </view>

      <!-- 设计图 -->
      <view wx:if="{{phase.design_images && phase.design_images.length > 0}}" class="section">
        <view class="section-title"><text>设计图（{{phase.design_images.length}}张）</text></view>
        <view class="image-grid">
          <view wx:for="{{phase.design_images}}" wx:key="index" class="image-item">
            <image lazy-load src="{{item}}" mode="aspectFill" class="image-thumb" bindtap="onPreview" data-url="{{item}}" />
          </view>
        </view>
      </view>

      <!-- 已上传完工图 -->
      <view wx:if="{{phase.construction_images && phase.construction_images.length > 0}}" class="section">
        <view class="section-title"><text>已上传完工图（{{phase.construction_images.length}}张）</text></view>
        <view class="image-grid">
          <view wx:for="{{phase.construction_images}}" wx:key="index" class="image-item">
            <image lazy-load src="{{item}}" mode="aspectFill" class="image-thumb" bindtap="onPreview" data-url="{{item}}" />
          </view>
        </view>
      </view>

      <!-- 上传新完工图 -->
      <view wx:if="{{phase.status === 'construction_confirmed' || phase.status === 'engineering_director_rejected' || phase.status === 'construction_admin_rejected'}}" class="section">
        <view class="section-title"><text>上传完工图</text></view>
        <view wx:if="{{selectedImages.length > 0}}" class="image-grid">
          <block wx:for="{{selectedImages}}" wx:key="path">
            <view class="image-item">
              <image lazy-load src="{{item}}" mode="aspectFill" class="image-thumb"/>
              <view class="image-remove" bindtap="onRemoveImage" data-index="{{index}}">✕</view>
            </view>
          </block>
          <view wx:if="{{selectedImages.length < 9}}" class="image-add" bindtap="onChooseImages">
            <text class="add-icon">+</text>
          </view>
        </view>
        <view wx:else class="image-add-large" bindtap="onChooseImages">
          <text class="add-icon">+</text><text class="add-text">选择图片</text>
        </view>
        <!-- 施工描述（可选） -->
        <view class="desc-section">
          <view class="section-title"><text>施工描述</text><text class="optional-hint">（选填）</text></view>
          <textarea class="desc-textarea" placeholder="例如：已按设计图完成水电布线，管道压力测试合格..." value="{{constructionDescription}}" bindinput="onDescriptionInput" maxlength="500" auto-height />
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </block>
  </block>

  <!-- 确认设计按钮 -->
  <view wx:if="{{ready && phase && (phase.status === 'design_admin_approved' || phase.status === 'owner_design_reviewed')}}" class="action-bar">
    <button class="action-btn accept-btn" bindtap="onConfirmDesign" loading="{{acting}}" disabled="{{acting}}">
      <text class="zhficon"></text> 确认设计图无误
    </button>
  </view>

  <!-- 上传完工图按钮 -->
  <view wx:if="{{ready && phase && (phase.status === 'construction_confirmed' || phase.status === 'engineering_director_rejected' || phase.status === 'construction_admin_rejected')}}" class="action-bar">
    <button class="action-btn accept-btn" bindtap="onSubmitConstruction" loading="{{uploading}}" disabled="{{uploading}}">
      {{uploading ? '上传中...' : '提交完工图'}}
    </button>
  </view>
</view>
