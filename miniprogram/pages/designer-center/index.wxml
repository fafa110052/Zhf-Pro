<!--
  и®ҫи®ЎеёҲдёӯеҝғ
  дёӘдәәдҝЎжҒҜ + з»ҹи®Ў + еҝ«жҚ·е…ҘеҸЈ + зј–иҫ‘иө„ж–ҷ
-->
<view class="page">

  <!-- в•җв•җв•җ еӨҙйғЁеҗҚзүҮ в•җв•җв•җ -->
  <view class="header-card">
    <view class="avatar-section">
      <!-- еӨҙеғҸпјҲеҸҜзӮ№еҮ»йў„и§ҲеӨ§еӣҫпјү -->
      <view class="avatar-wrap" bindtap="onPreviewAvatar">
        <image
          wx:if="{{userInfo.avatar_url}}"
          class="avatar-img"
          src="{{userInfo.avatar_url}}"
          mode="aspectFill"
        />
        <text wx:else class="avatar-placeholder zhficon">п„Ӯ</text>
        <view wx:if="{{userInfo.avatar_url}}" class="avatar-hint-badge">
          <text class="zhficon">п„ғ</text>
        </view>
        <!-- еӨҙеғҸе®Ўж ёдёӯж Үи®° -->
        <view wx:if="{{userInfo.avatar_review_status === 'pending'}}" class="avatar-pending-badge">
          <text class="zhficon">п„Ј</text>
        </view>
      </view>

      <text class="name-text">{{userInfo.name || 'жңӘи®ҫзҪ®'}}</text>
      <!-- еӨҙеғҸе®Ўж ёзҠ¶жҖҒжҸҗзӨә -->
      <text wx:if="{{userInfo.avatar_review_status === 'pending'}}" class="avatar-pending-text">еӨҙеғҸе®Ўж ёдёӯвҖҰ</text>
      <text wx:if="{{userInfo.phone}}" class="phone-text">{{userInfo.phone}}</text>

      <!-- д»Һдёҡе№ҙйҷҗж Үзӯҫ -->
      <view wx:if="{{userInfo.years_of_exp > 0}}" class="exp-badge">
        <text><text class="zhficon">п„Ҹ</text> д»Һдёҡ {{userInfo.years_of_exp}} е№ҙ</text>
      </view>

    </view>
  </view>

  <!-- в•җв•җв•җ ж•°жҚ®жҰӮи§Ҳ в•җв•җв•җ -->
  <view class="stats-row">
    <view wx:for="{{statsText}}" wx:key="label" class="stat-box">
      <text class="stat-num {{item.color}}">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <!-- в•җв•җв•җ еҝ«жҚ·е…ҘеҸЈ в•җв•җв•җ -->
  <view class="quick-actions">
    <view class="action-card action-primary" bindtap="onGoUpload">
      <text class="action-icon zhficon">п„Ў</text>
      <text class="action-label">дёҠдј дҪңе“Ғ</text>
      <text class="action-desc">ж–°зҡ„иЈ…дҝ®жЎҲдҫӢ</text>
    </view>
    <view class="action-card action-secondary" bindtap="onGoWorks">
      <text class="action-icon zhficon">п„–</text>
      <text class="action-label">з®ЎзҗҶдҪңе“Ғ</text>
      <text class="action-desc">{{stats.total}} дёӘдҪңе“Ғ</text>
    </view>
  </view>

  <!-- в•җв•җв•җ жҹҘзңӢжЁЎејҸ в•җв•җв•җ -->
  <view wx:if="{{!editing}}" class="info-card card">
    <view class="card-header">
      <text class="card-title">дёӘдәәдҝЎжҒҜ</text>
      <text class="edit-btn" bindtap="onEdit"><text class="zhficon">п„ӣ</text> зј–иҫ‘</text>
    </view>

    <view class="info-list">
      <!-- е§“еҗҚ -->
      <view class="info-row">
        <view class="info-label-wrap">
          <text class="info-icon zhficon">п„Ӯ</text>
          <text class="info-label">е§“еҗҚ</text>
        </view>
        <text class="info-value">{{userInfo.name || 'жңӘи®ҫзҪ®'}}</text>
      </view>

      <!-- жүӢжңәеҸ· -->
      <view class="info-row">
        <view class="info-label-wrap">
          <text class="info-icon zhficon">п„…</text>
          <text class="info-label">жүӢжңәеҸ·</text>
        </view>
        <text class="info-value">{{userInfo.phone || 'жңӘи®ҫзҪ®'}}</text>
      </view>

      <!-- д»Һдёҡз»ҸйӘҢ -->
      <view class="info-row">
        <view class="info-label-wrap">
          <text class="info-icon zhficon">п„Ҹ</text>
          <text class="info-label">д»Һдёҡз»ҸйӘҢ</text>
        </view>
        <text class="info-value">{{userInfo.years_of_exp ? userInfo.years_of_exp + ' е№ҙ' : 'жңӘи®ҫзҪ®'}}</text>
      </view>

      <!-- жіЁеҶҢж—¶й—ҙ -->
      <view class="info-row" wx:if="{{userInfo.created_at}}">
        <view class="info-label-wrap">
          <text class="info-icon zhficon">п„ң</text>
          <text class="info-label">жіЁеҶҢж—¶й—ҙ</text>
        </view>
        <text class="info-value">{{userInfo.created_at}}</text>
      </view>
    </view>

    <!-- дёӘдәәз®Җд»Ӣ -->
    <view class="bio-section">
      <view class="bio-header">
        <text class="info-icon zhficon">п„қ</text>
        <text class="bio-title">дёӘдәәз®Җд»Ӣ</text>
      </view>
      <view wx:if="{{userInfo.bio}}" class="bio-content">
        <text>{{userInfo.bio}}</text>
      </view>
      <view wx:else class="bio-empty">
        <text>иҝҷдёӘдәәеҫҲжҮ’пјҢиҝҳжІЎеҶҷз®Җд»ӢвҖҰ</text>
        <text class="bio-empty-hint" bindtap="onEdit">еҶҷдёҖеҸҘ</text>
      </view>
    </view>
  </view>

  <!-- в•җв•җв•җ зј–иҫ‘жЁЎејҸ в•җв•җв•җ -->
  <view wx:else class="edit-card card">
    <view class="card-header">
      <text class="card-title">зј–иҫ‘иө„ж–ҷ</text>
      <text class="cancel-btn" bindtap="onCancelEdit">еҸ–ж¶Ҳ</text>
    </view>

    <!-- еӨҙеғҸзј–иҫ‘ -->
    <view class="edit-avatar" bindtap="onChooseAvatar">
      <image
        wx:if="{{editForm.avatar_preview}}"
        class="edit-avatar-img"
        src="{{editForm.avatar_preview}}"
        mode="aspectFill"
      />
      <view wx:else class="edit-avatar-placeholder">
        <text class="edit-avatar-icon zhficon">п„һ</text>
      </view>
      <text class="edit-avatar-hint">зӮ№еҮ»жӣҙжҚўеӨҙеғҸ</text>
    </view>

    <!-- иЎЁеҚ• -->
    <view class="edit-form">
      <!-- е§“еҗҚ -->
      <view class="form-item">
        <view class="form-label-row">
          <text class="form-label">е§“еҗҚ</text>
          <text class="form-required">*</text>
        </view>
        <input
          class="form-input"
          value="{{editForm.name}}"
          data-field="name"
          bindinput="onFieldChange"
          placeholder="иҜ·иҫ“е…Ҙе§“еҗҚ"
        />
      </view>

      <!-- жүӢжңәеҸ· -->
      <view class="form-item">
        <view class="form-label-row">
          <text class="form-label">жүӢжңәеҸ·</text>
        </view>
        <input
          class="form-input"
          type="number"
          maxlength="11"
          value="{{editForm.phone}}"
          data-field="phone"
          bindinput="onFieldChange"
          placeholder="иҜ·иҫ“е…ҘжүӢжңәеҸ·"
        />
      </view>

      <!-- д»Һдёҡе№ҙйҷҗ -->
      <view class="form-item">
        <view class="form-label-row">
          <text class="form-label">д»Һдёҡз»ҸйӘҢпјҲе№ҙпјү</text>
        </view>
        <view class="exp-stepper">
          <view class="exp-dot {{editForm.years_of_exp >= 1 ? 'active' : ''}}" />
          <view class="exp-line {{editForm.years_of_exp >= 2 ? 'active' : ''}}" />
          <view class="exp-dot {{editForm.years_of_exp >= 2 ? 'active' : ''}}" />
          <view class="exp-line {{editForm.years_of_exp >= 3 ? 'active' : ''}}" />
          <view class="exp-dot {{editForm.years_of_exp >= 3 ? 'active' : ''}}" />
          <view class="exp-line {{editForm.years_of_exp >= 5 ? 'active' : ''}}" />
          <view class="exp-dot {{editForm.years_of_exp >= 5 ? 'active' : ''}}" />
          <view class="exp-line {{editForm.years_of_exp >= 8 ? 'active' : ''}}" />
          <view class="exp-dot {{editForm.years_of_exp >= 8 ? 'active' : ''}}" />
          <view class="exp-line {{editForm.years_of_exp >= 10 ? 'active' : ''}}" />
          <view class="exp-dot {{editForm.years_of_exp >= 10 ? 'active' : ''}}" />
        </view>
        <input
          class="form-input"
          type="number"
          value="{{editForm.years_of_exp}}"
          data-field="years_of_exp"
          bindinput="onFieldChange"
          placeholder="еҰӮпјҡ5"
        />
      </view>

      <!-- дёӘдәәз®Җд»Ӣ -->
      <view class="form-item">
        <view class="form-label-row">
          <text class="form-label">дёӘдәәз®Җд»Ӣ</text>
          <text class="form-counter">{{editForm.bioLength || 0}}/200</text>
        </view>
        <textarea
          class="form-textarea"
          value="{{editForm.bio}}"
          data-field="bio"
          bindinput="onFieldChange"
          placeholder="з®ҖеҚ•д»Ӣз»ҚдёҖдёӢиҮӘе·ұпјҢи®©е®ўжҲ·жӣҙдәҶи§ЈдҪ вҖҰ"
          maxlength="200"
        />
      </view>
    </view>

    <button class="btn btn-primary btn-block save-btn" bindtap="onSave" disabled="{{saving}}">
      <text class="zhficon">п„ҹ</text> {{saving ? 'дҝқеӯҳдёӯ...' : 'дҝқеӯҳиө„ж–ҷ'}}
    </button>

    <!-- жҸҗзӨә -->
    <view class="edit-notice">
      <text><text class="zhficon">п„ </text> жүӢжңәеҸ·еҸҳжӣҙеҗҺдёӢж¬Ўзҷ»еҪ•йңҖдҪҝз”Ёж–°жүӢжңәеҸ·</text>
    </view>
  </view>

  <!-- еә•йғЁе®үе…ЁеҢә -->
  <view class="safe-bottom"></view>
</view>
