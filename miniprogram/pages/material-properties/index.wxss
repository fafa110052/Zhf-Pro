/* 在线选材 — 楼盘列表（蓝金配色） */
.page {
  min-height: 100vh;
  background: #f0f4f8;
}

/* ═══ Loading ═══ */
.page-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f0f4f8;
}

.loading-dot-pulse {
  display: flex;
  gap: 12rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  background: #1478dc;
  border-radius: 50%;
  animation: dotPulse 1.4s ease-in-out infinite both;
}

.dot:nth-child(1) { animation-delay: 0s; }
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% { transform: scale(0.4); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

.loading-hint {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: #94a3b8;
}

/* ═══ Error ═══ */
.page-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f0f4f8;
}

.error-icon {
  width: 96rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 48rpx;
  background: #fef2f2;
  color: #dc2626;
  font-size: 52rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.error-msg {
  font-size: 32rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.error-hint {
  font-size: 24rpx;
  color: #1478dc;
}

/* ═══ 搜索栏 ═══ */
.search-bar {
  padding: 20rpx 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #e8eef4;
  border-radius: 40rpx;
  padding: 16rpx 26rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.search-box:focus-within {
  border-color: #1478dc;
  background: #fff;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  opacity: 0.35;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

.search-clear {
  padding: 6rpx 14rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

/* ═══ 楼盘列表 ═══ */
.property-list {
  padding: 12rpx 24rpx 40rpx;
}

/* ── 卡片 ── */
.property-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 18rpx;
  padding: 20rpx 20rpx 20rpx 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(20, 120, 220, 0.06);
  position: relative;
  overflow: hidden;
}

/* 蓝色左侧强调线 */
.property-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #1478dc, #3cb4f0);
}

.property-card:active {
  background: #f8fafe;
}

/* ── 封面图 ── */
.card-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 14rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.card-img {
  width: 100%;
  height: 100%;
  background: #e8eef4;
}

.card-img-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #dbeafe, #bfdbfe);
}

.fallback-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #1478dc;
  letter-spacing: 4rpx;
}

/* ── 信息区 ── */
.card-body {
  flex: 1;
  margin-left: 22rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e3a5f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.card-address {
  font-size: 24rpx;
  color: #5c7a9e;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 14rpx;
}

/* ── 标签 ── */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-blue {
  background: #e8f2fd;
  color: #1478dc;
  border: 1rpx solid #c8ddf6;
}

/* ── 箭头 ── */
.card-arrow {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #e8f2fd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.card-arrow text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1478dc;
  margin-top: -2rpx;
}

/* ═══ 空状态 ═══ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx 48rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #e8f2fd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.empty-icon {
  font-size: 64rpx;
  font-weight: 300;
  color: #1478dc;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  line-height: 1.6;
}
