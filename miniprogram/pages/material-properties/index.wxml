<!-- 楼盘筛选页 — 在线选材入口 -->
<view class="page">
  <!-- ═══ 搜索栏 ═══ -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索楼盘名称"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <view wx:if="{{keyword}}" class="search-clear" bindtap="onClearSearch">
        <text>✕</text>
      </view>
    </view>
  </view>

  <!-- ═══ 楼盘列表 ═══ -->
  <view wx:if="{{!loading && !error}}" class="property-list">
    <block wx:if="{{properties.length > 0}}">
      <view
        wx:for="{{properties}}"
        wx:key="id"
        class="property-card"
        data-id="{{item.id}}"
        data-name="{{item.name}}"
        bindtap="onPropertyTap"
      >
        <image
          wx:if="{{item.cover_image}}"
          class="property-cover"
          src="{{item.cover_image}}"
          mode="aspectFill"
        />
        <view wx:else class="property-cover-placeholder">
          <text class="placeholder-icon">🏠</text>
        </view>
        <view class="property-info">
          <text class="property-name">{{item.name}}</text>
          <text class="property-address">{{item.address}}</text>
          <view class="property-badge">
            <text class="badge-text">支持在线选材</text>
          </view>
        </view>
        <view class="property-arrow">
          <text>›</text>
        </view>
      </view>
    </block>

    <!-- 空状态 -->
    <view wx:if="{{properties.length === 0}}" class="empty-state">
      <text class="empty-icon">📋</text>
      <text class="empty-title">暂无可用楼盘</text>
      <text class="empty-desc">{{keyword ? '未找到匹配的楼盘，试试其他关键词' : '暂未开通在线选材服务'}}</text>
    </view>
  </view>

  <!-- 首次加载中 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 加载失败 -->
  <view wx:if="{{error}}" class="error-state" bindtap="onRetry">
    <text class="error-icon">⚠️</text>
    <text class="error-msg">加载失败</text>
    <text class="error-hint">点击重试</text>
  </view>
</view>
