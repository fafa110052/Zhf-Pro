<!-- 在线选材 — 楼盘列表 -->
<view class="page">
  <!-- ready 前：仅背景色 -->
  <view wx:if="{{!ready}}" class="page-loading">
    <view class="loading-dot-pulse">
      <view class="dot"></view><view class="dot"></view><view class="dot"></view>
    </view>
    <text class="loading-hint">加载中...</text>
  </view>

  <block wx:if="{{ready}}">
    <!-- Error -->
    <view wx:if="{{error}}" class="page-error" bindtap="onRetry">
      <text class="error-icon">!</text>
      <text class="error-msg">加载失败</text>
      <text class="error-hint">点击重试</text>
    </view>

    <block wx:else>
      <!-- 搜索栏 -->
      <view class="search-bar">
        <view class="search-box">
          <text class="search-icon">🔍</text>
          <input
            class="search-input"
            placeholder="搜索楼盘名称"
            value="{{keyword}}"
            bindinput="onSearchInput"
            bindconfirm="onSearchConfirm"
            confirm-type="search"
          />
          <view wx:if="{{keyword}}" class="search-clear" bindtap="onClearSearch">
            <text>✕</text>
          </view>
        </view>
      </view>

      <!-- 楼盘列表 -->
      <view class="property-list">
        <block wx:if="{{properties.length > 0}}">
          <view
            wx:for="{{properties}}"
            wx:key="id"
            class="property-card"
            data-id="{{item.id}}"
            data-name="{{item.name}}"
            bindtap="onPropertyTap"
          >
            <!-- 封面图 -->
            <view class="card-cover">
              <image
                wx:if="{{item.cover_url}}"
                class="card-img"
                src="{{item.cover_url}}"
                mode="aspectFill"
                lazy-load
              />
              <view wx:else class="card-img-fallback">
                <text class="fallback-text">住好房</text>
              </view>
            </view>

            <!-- 信息区 -->
            <view class="card-body">
              <text class="card-name">{{item.name}}</text>
              <text class="card-address">{{item.address}}</text>
              <view class="card-tags">
                <view class="tag tag-blue">
                  <text>支持在线选材</text>
                </view>
              </view>
            </view>

            <!-- 箭头 -->
            <view class="card-arrow">
              <text>›</text>
            </view>
          </view>
        </block>

        <!-- 空状态 -->
        <view wx:if="{{properties.length === 0}}" class="empty-state">
          <view class="empty-icon-wrap">
            <text class="empty-icon">+</text>
          </view>
          <text class="empty-title">暂无可用楼盘</text>
          <text class="empty-desc">{{keyword ? '未找到匹配的楼盘，试试其他关键词' : '暂未开通在线选材服务'}}</text>
        </view>
      </view>
    </block>
  </block>
</view>
