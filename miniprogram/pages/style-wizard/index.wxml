<!-- 风格选材向导页 -->
<view class="page">
  <block wx:if="{{ready}}">
    <!-- 加载失败 -->
    <view wx:if="{{error}}" class="page-error">
      <text class="error-msg">加载失败，请检查网络后重试</text>
      <view class="retry-btn" bindtap="onRetry">重新加载</view>
    </view>

    <block wx:else>
      <!-- 品类头图：固定顶部，表单卡片上滑覆盖，随滚动虚化缩小 -->
      <view wx:if="{{heroImage}}" class="step-hero" style="transform: scale({{1 - heroProgress * 0.08}}); opacity: {{1 - heroProgress * 0.3}};">
        <image class="hero-img" src="{{heroImage}}" mode="aspectFill" />
        <image class="hero-img hero-blur" style="opacity: {{heroProgress}};" src="{{heroImage}}" mode="aspectFill" />
      </view>

      <!-- 内容卡片：顶部圆角，上滑盖住头图，滑过后即页面原样 -->
      <view class="sheet {{heroImage ? 'has-hero' : ''}}">
        <!-- 7 步进度 -->
        <progress-steps steps="{{steps}}" current="{{step}}" />

        <!-- Editorial 标题带 -->
        <view class="title-band">
          <image class="band-num" src="/assets/icons/num-{{step}}.svg" mode="aspectFit" />
          <text class="band-title">{{currentCategory.name}}</text>
          <text class="band-en">{{stepEnglish}}</text>
        </view>

      <view class="step-body">
        <!-- ─── 通用步骤（1/3/4/5/6）：子品类手风琴 ─── -->
        <block wx:if="{{stepType === 'generic'}}">
          <accordion-card
            wx:for="{{currentCategory.subcategories}}"
            wx:key="id"
            number="{{index + 1}}"
            title="{{item.name}}"
            expanded="{{expandedSub === item.id}}"
            completed="{{!!selections['sub_' + item.id]}}"
            selected-label="{{selections['sub_' + item.id].kind === 'skip' ? '已跳过' : (selections['sub_' + item.id].name || '')}}"
            data-id="{{item.id}}"
            bind:toggle="onToggleSub"
          >
            <!-- 卫生间门：系列→颜色选择（复用门步骤模式） -->
            <block wx:if="{{item.isBathDoor}}">
              <view wx:if="{{bathDoorLoading}}" class="body-hint">加载中…</view>
              <view wx:elif="{{bathDoorError}}" class="body-retry" catchtap="onRetryBathDoorSeries">加载失败，点此重试</view>
              <view wx:elif="{{!bathDoorSeries.length}}" class="body-hint">暂无卫生间门系列</view>
              <block wx:else>
                <view class="door-section-title">
                  <text class="door-section-num">1</text>
                  <text>选择门系列</text>
                </view>
                <view class="series-grid">
                  <view
                    wx:for="{{bathDoorSeries}}"
                    wx:key="id"
                    class="series-card {{bathDoorChosenSeriesId === item.id ? 'is-selected' : ''}}"
                    data-id="{{item.id}}"
                    bindtap="onSelectBathDoorSeries"
                  >
                    <image class="series-image" src="{{item.image_url}}" mode="aspectFill" />
                    <image wx:if="{{bathDoorChosenSeriesId === item.id}}" class="mat-badge" src="/assets/icons/selected-mark.svg" mode="aspectFit" />
                    <view class="series-info">
                      <text class="series-name">{{item.name}}</text>
                    </view>
                  </view>
                </view>
                <block wx:if="{{bathDoorChosenSeriesId}}">
                  <view class="door-section-title">
                    <text class="door-section-num">2</text>
                    <text>选择门的颜色</text>
                  </view>
                  <view wx:if="{{loadingSubId === bathDoorChosenSeriesId}}" class="body-hint">加载中…</view>
                  <view wx:elif="{{errorSubId === bathDoorChosenSeriesId}}" class="body-retry" data-series-id="{{bathDoorChosenSeriesId}}" catchtap="onRetryBathDoorMaterials">加载失败，点此重试</view>
                  <block wx:else>
                    <view wx:if="{{!bathDoorMaterialsCache['s' + bathDoorChosenSeriesId].length}}" class="body-hint">该系列暂无此风格门型</view>
                    <view wx:else class="color-grid">
                      <view
                        wx:for="{{bathDoorMaterialsCache['s' + bathDoorChosenSeriesId]}}"
                        wx:for-item="dm"
                        wx:key="id"
                        class="color-card {{pending && pending.materialId === dm.id ? 'is-selected' : ''}}"
                        data-id="{{dm.id}}"
                        bindtap="onSelectBathDoorColor"
                      >
                        <image class="color-swatch" src="{{dm.image_url}}" mode="aspectFill" />
                        <text class="color-name">{{dm.color_name}}</text>
                        <text wx:if="{{dm.specs}}" class="color-specs">{{dm.specs}}</text>
                      </view>
                    </view>
                  </block>
                </block>
                <!-- 锁向选择（复用现有 direction-chooser） -->
                <view wx:if="{{pending && pending.subId === item.id}}" class="direction-chooser">
                  <text class="chooser-title">请选择锁向</text>
                  <view class="chooser-btns">
                    <view
                      class="chooser-btn"
                      wx:for="{{pending.options}}"
                      wx:for-item="opt"
                      wx:key="*this"
                      data-value="{{opt}}"
                      catchtap="onChooseDirection"
                    >{{opt}}</view>
                  </view>
                </view>
                <view wx:if="{{!bathDoorSeries.length && bathDoorLoaded}}" class="skip-btn" data-sub-id="{{item.id}}" catchtap="onSkipSub">此项不选</view>
              </block>
            </block>

            <!-- 普通子品类：材料网格 -->
            <block wx:else>
            <view wx:if="{{loadingSubId === item.id}}" class="body-hint">加载中…</view>
            <block wx:elif="{{errorSubId === item.id}}">
              <view class="body-retry" data-sub-id="{{item.id}}" catchtap="onRetryMaterials">加载失败，点此重试</view>
              <view class="skip-btn" data-sub-id="{{item.id}}" catchtap="onSkipSub">此项不选</view>
            </block>
            <block wx:else>
              <view wx:if="{{!materialsCache['s' + item.id].length}}" class="body-hint">暂无可选材料</view>
              <view wx:else class="material-grid">
                <view
                  wx:for="{{materialsCache['s' + item.id]}}"
                  wx:for-item="mat"
                  wx:for-index="mIdx"
                  wx:key="id"
                  class="material-card {{selections['sub_' + item.id].id === mat.id || (pending && pending.subId === item.id && pending.materialId === mat.id) ? 'is-selected' : ''}}"
                  data-sub-id="{{item.id}}"
                  data-index="{{mIdx}}"
                  bindtap="onSelectMaterial"
                >
                  <image class="mat-image" src="{{mat.image_url}}" mode="aspectFill" />
                  <!-- 放大改为独立按钮，图片区域点击即选中，避免误触 -->
                  <view class="mat-zoom" data-sub-id="{{item.id}}" data-index="{{mIdx}}" catchtap="onZoomImage">
                    <image class="mat-zoom-icon" src="/assets/icons/zoom-in.svg" mode="aspectFit" />
                    <text>放大</text>
                  </view>
                  <image wx:if="{{selections['sub_' + item.id].id === mat.id}}" class="mat-badge" src="/assets/icons/selected-mark.svg" mode="aspectFit" />
                  <view class="mat-info">
                    <!-- 有名称按名称展示；无名称（瓷砖类）标题行 = 品牌logo + 品牌名 -->
                    <block wx:if="{{mat.name}}">
                      <text class="mat-name">{{mat.name}}</text>
                      <text wx:if="{{mat.brand_model}}" class="mat-brand">{{mat.brand_model}}</text>
                    </block>
                    <block wx:elif="{{mat.brand}}">
                      <view class="mat-brand-row">
                        <image wx:if="{{mat.brand_logo}}" class="mat-logo" src="{{mat.brand_logo}}" mode="aspectFit" />
                        <text class="mat-name">{{mat.brand}}</text>
                      </view>
                      <text wx:if="{{mat.model}}" class="mat-brand">型号：{{mat.model}}</text>
                    </block>
                    <text wx:if="{{mat.specs}}" class="mat-specs">规格：{{mat.specs}}</text>
                    <text wx:if="{{mat.old_code}}" class="mat-code">老编码：{{mat.old_code}}</text>
                    <text wx:if="{{mat.new_code}}" class="mat-code">新编码：{{mat.new_code}}</text>
                    <view wx:if="{{mat.scopes.length}}" class="mat-scopes">
                      <text class="scope-tag" wx:for="{{mat.scopes}}" wx:for-item="sc" wx:key="*this">✓ {{sc}}</text>
                    </view>
                    <view wx:if="{{mat.attrList.length}}" class="mat-attrs">
                      <text class="attr-line" wx:for="{{mat.attrList}}" wx:for-item="attr" wx:key="k">{{attr.k}} {{attr.v}}</text>
                    </view>
                    <view wx:if="{{mat.original_price != null || mat.discount_price != null}}" class="price-row">
                      <text wx:if="{{mat.original_price != null}}" class="price-original">¥{{mat.original_price}}</text>
                      <text wx:if="{{mat.discount_price != null}}" class="price-discount">¥{{mat.discount_price}}</text>
                    </view>
                  </view>
                </view>
              </view>

              <!-- 方向选择：卫生间门锁向 / 沙发贵妃位 -->
              <view wx:if="{{pending && pending.subId === item.id}}" class="direction-chooser">
                <text class="chooser-title">{{pending.type === 'lock' ? '请选择锁向' : '请选择贵妃位方向'}}</text>
                <view class="chooser-btns">
                  <view
                    class="chooser-btn"
                    wx:for="{{pending.options}}"
                    wx:for-item="opt"
                    wx:key="*this"
                    data-value="{{opt}}"
                    catchtap="onChooseDirection"
                  >{{opt}}</view>
                </view>
              </view>

              <view wx:if="{{!materialsCache['s' + item.id] || !materialsCache['s' + item.id].length}}" class="skip-btn" data-sub-id="{{item.id}}" catchtap="onSkipSub">此项不选</view>
            </block>
            </block>
          </accordion-card>
        </block>

        <!-- ─── 第 2 步：木门系列（先选系列，再选颜色） ─── -->
        <block wx:elif="{{stepType === 'door'}}">
          <view wx:if="{{doorLoading}}" class="body-hint step-hint">加载中…</view>
          <view wx:elif="{{doorError}}" class="body-retry step-hint" bindtap="onRetryDoorSeries">加载失败，点此重试</view>
          <view wx:elif="{{!doorSeries.length}}" class="body-hint step-hint">暂无门系列</view>
          <block wx:else>
            <!-- 第一层：门系列单选（主图 + 系列名） -->
            <view class="door-section-title">
              <text class="door-section-num">1</text>
              <text>选择门系列</text>
            </view>
            <view class="series-grid">
              <view
                wx:for="{{doorSeries}}"
                wx:key="id"
                class="series-card {{chosenSeriesId === item.id ? 'is-selected' : ''}}"
                data-id="{{item.id}}"
                bindtap="onSelectSeries"
              >
                <image class="series-image" src="{{item.image_url}}" mode="aspectFill" />
                <image wx:if="{{chosenSeriesId === item.id}}" class="mat-badge" src="/assets/icons/selected-mark.svg" mode="aspectFit" />
                <view class="series-info">
                  <text class="series-name">{{item.name}}</text>
                  <text wx:if="{{selections.door.series_id === item.id}}" class="series-chosen">已选：{{selections.door.color_name}}</text>
                </view>
              </view>
            </view>

            <!-- 第二层：所选系列下的颜色 -->
            <block wx:if="{{chosenSeriesId}}">
              <view class="door-section-title">
                <text class="door-section-num">2</text>
                <text>选择门的颜色</text>
              </view>
              <view wx:if="{{loadingSubId === chosenSeriesId}}" class="body-hint">加载中…</view>
              <view wx:elif="{{errorSubId === chosenSeriesId}}" class="body-retry" data-series-id="{{chosenSeriesId}}" catchtap="onRetryDoorMaterials">加载失败，点此重试</view>
              <block wx:else>
                <view wx:if="{{!doorMaterialsCache['s' + chosenSeriesId].length}}" class="body-hint">该系列暂无此风格门型</view>
                <view wx:else class="color-grid">
                  <view
                    wx:for="{{doorMaterialsCache['s' + chosenSeriesId]}}"
                    wx:for-item="dm"
                    wx:key="id"
                    class="color-card {{selections.door.series_id === chosenSeriesId && selections.door.color_id === dm.color_id ? 'is-selected' : ''}}"
                    data-id="{{dm.id}}"
                    bindtap="onSelectDoor"
                  >
                    <image class="color-swatch" src="{{dm.image_url}}" mode="aspectFill" />
                    <image wx:if="{{selections.door.series_id === chosenSeriesId && selections.door.color_id === dm.color_id}}" class="color-badge" src="/assets/icons/selected-mark.svg" mode="aspectFit" />
                    <text class="color-name">{{dm.color_name}}</text>
                    <text wx:if="{{dm.specs}}" class="color-specs">{{dm.specs}}</text>
                    <view wx:if="{{dm.original_price != null || dm.discount_price != null}}" class="price-row price-center">
                      <text wx:if="{{dm.original_price != null}}" class="price-original">¥{{dm.original_price}}</text>
                      <text wx:if="{{dm.discount_price != null}}" class="price-discount">¥{{dm.discount_price}}</text>
                    </view>
                  </view>
                </view>
              </block>
            </block>
          </block>
          <view wx:if="{{!doorSeries.length && doorLoaded}}" class="skip-btn" catchtap="onSkipDoor">此项不选</view>
        </block>

        <!-- ─── 第 7 步：灯具套餐 ─── -->
        <block wx:elif="{{stepType === 'lighting'}}">
          <view wx:if="{{lightingLoading}}" class="body-hint step-hint">加载中…</view>
          <view wx:elif="{{lightingError}}" class="body-retry step-hint" bindtap="onRetryLighting">加载失败，点此重试</view>
          <view wx:elif="{{!lightingPackages.length}}" class="body-hint step-hint">暂无灯具套餐</view>
          <block wx:else>
            <view
              wx:for="{{lightingPackages}}"
              wx:key="id"
              class="pkg-card {{selections.lighting.package_id === item.id ? 'is-selected' : ''}}"
              data-id="{{item.id}}"
              bindtap="onSelectLighting"
            >
              <image class="pkg-image" src="{{item.image_url}}" mode="aspectFill" />
              <image wx:if="{{selections.lighting.package_id === item.id}}" class="pkg-badge" src="/assets/icons/selected-mark.svg" mode="aspectFit" />
              <view class="pkg-info">
                <view class="pkg-title-row">
                  <text class="pkg-name">{{item.name}}</text>
                  <view wx:if="{{item.original_price != null || item.discount_price != null}}" class="price-row">
                    <text wx:if="{{item.original_price != null}}" class="price-original">¥{{item.original_price}}</text>
                    <text wx:if="{{item.discount_price != null}}" class="price-discount pkg-price">¥{{item.discount_price}}</text>
                  </view>
                </view>
                <text wx:if="{{item.itemsSummary}}" class="pkg-summary">{{item.itemsSummary}}</text>

                <view class="pkg-toggle" data-id="{{item.id}}" catchtap="onTogglePackage">
                  <text>{{expandedPackage === item.id ? '收起明细' : '查看明细'}}</text>
                  <image class="pkg-chevron {{expandedPackage === item.id ? 'is-up' : ''}}" src="/assets/icons/chevron-down.svg" mode="aspectFit" />
                </view>

                <view wx:if="{{expandedPackage === item.id}}" class="pkg-items">
                  <view class="pkg-item" wx:for="{{item.items}}" wx:for-item="it" wx:key="id">
                    <image class="item-image" src="{{it.image_url}}" mode="aspectFill" />
                    <view class="item-info">
                      <text class="item-name">{{it.room_type ? it.room_type + ' · ' : ''}}{{it.name}}</text>
                      <text wx:if="{{it.attrsLine}}" class="item-attrs">{{it.attrsLine}}</text>
                      <text wx:if="{{it.retail_price != null}}" class="item-price">零售价¥{{it.retail_price}}</text>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </block>
          <view wx:if="{{!lightingPackages.length && lightingLoaded}}" class="skip-btn" catchtap="onSkipLighting">此项不选</view>
        </block>
      </view>
      </view>

      <!-- 底部操作栏 -->
      <view class="bottom-bar">
        <view wx:if="{{step > 1}}" class="prev-btn" bindtap="onPrevStep">上一步</view>
        <view class="next-btn {{stepComplete ? '' : 'is-disabled'}}" bindtap="onNextStep">{{step === 7 ? '查看选材清单' : '下一步'}}</view>
      </view>

      <!-- 图片放大预览 -->
      <image-lightbox
        images="{{lightboxImages}}"
        current-index="{{lightboxIndex}}"
        visible="{{lightboxVisible}}"
        selected-id="{{lightboxSelectedId}}"
        bind:close="onLightboxClose"
        bind:select="onLightboxSelect"
      />
    </block>
  </block>
</view>
