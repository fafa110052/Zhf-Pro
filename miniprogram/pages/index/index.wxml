<!-- 首页 V3.0 — 温暖精致风 -->
<view class="page">

  <!-- ═══ Banner 轮播 ═══ -->
  <view wx:if="{{!bannerLoading && banners.length > 0}}" class="banner-section">
    <swiper-banner
      banners="{{banners}}"
      height="{{420}}"
      bindtap="onBannerTap"
    />
  </view>
  <view wx:elif="{{!bannerLoading && banners.length === 0}}" class="banner-empty">
    <text class="banner-empty-icon">🏠</text>
    <text class="banner-empty-title">住好房装修展示平台</text>
    <text class="banner-empty-sub">让每个家，都住好</text>
  </view>

  <!-- ═══ 免费量房 ═══ -->
  <view class="section trust-section">
    <view class="section-header">
      <text class="section-title">免费量房</text>
    </view>

    <view class="trust-steps">
      <block wx:for="{{measureSteps}}" wx:key="label">
        <view class="trust-step">
          <view class="step-num-row">
            <view class="step-num">{{index + 1}}</view>
          </view>
          <view class="step-icon-wrap">
            <text class="step-icon">{{item.icon}}</text>
          </view>
          <text class="step-label">{{item.label}}</text>
          <text class="step-desc">{{item.desc}}</text>
        </view>
      </block>
    </view>

    <view class="measure-btn" bindtap="onFreeMeasureTap">
      <text class="measure-btn-text">免费预约量房</text>
    </view>
  </view>

  <!-- ═══ 为什么选择住好房 ═══ -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">为什么选择住好房</text>
    </view>

    <view class="adv-grid">
      <view wx:for="{{advantages}}" wx:key="label" class="adv-card">
        <view class="adv-icon-wrap">
          <text class="adv-icon">{{item.icon}}</text>
        </view>
        <text class="adv-label">{{item.label}}</text>
        <text class="adv-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- ═══ 设计团队 ═══ -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">设计团队</text>
    </view>

    <scroll-view wx:if="{{designers.length > 0}}" class="team-scroll" scroll-x enable-flex>
      <view class="team-list">
        <view wx:for="{{designers}}" wx:key="name" class="team-card">
          <view class="team-avatar-wrap">
            <image class="team-avatar" src="{{item.avatar}}" mode="aspectFill"/>
          </view>
          <text class="team-name">{{item.name}}</text>
          <text class="team-tag">{{item.styles}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="team-stats">
      <text class="team-stat"><text class="team-stat-num">500+</text> 服务家庭</text>
      <text class="team-stat-dot">·</text>
      <text class="team-stat"><text class="team-stat-num">1200+</text> 设计作品</text>
      <text class="team-stat-dot">·</text>
      <text class="team-stat"><text class="team-stat-num">98%</text> 好评率</text>
    </view>
  </view>

  <!-- ═══ 热门推荐 ═══ -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热门推荐</text>
      <text class="section-more" bindtap="onMoreHot">更多 ›</text>
    </view>

    <view wx:if="{{hotLoading}}" class="section-loading">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{hotError}}" class="section-error" bindtap="onRetryHot">
      <text class="error-icon">⚠️</text>
      <text class="error-text">加载失败，点击重试</text>
    </view>

    <view wx:elif="{{hotWorks.length > 0}}" class="hot-grid">
      <view class="hot-col">
        <block wx:for="{{hotWorks}}" wx:key="id">
          <view wx:if="{{index % 2 === 0}}" class="hot-item">
            <work-card work="{{item}}" showStyle="{{true}}" bindtap="onWorkTap"/>
          </view>
        </block>
      </view>
      <view class="hot-col">
        <block wx:for="{{hotWorks}}" wx:key="id">
          <view wx:if="{{index % 2 === 1}}" class="hot-item">
            <work-card work="{{item}}" showStyle="{{true}}" bindtap="onWorkTap"/>
          </view>
        </block>
      </view>
    </view>

    <empty-state wx:elif="{{hotWorks.length === 0}}"
      icon="🔥" title="暂无热门推荐" desc="管理员正在精选优质作品"/>
  </view>

  <view class="safe-bottom"></view>
</view>

<!-- ═══ 隐私协议弹窗 ═══ -->
<view wx:if="{{showPrivacy}}" class="privacy-overlay">
  <view class="privacy-sheet">
    <!-- 拖拽指示条 -->
    <view class="privacy-drag-bar"></view>

    <!-- 图标 -->
    <view class="privacy-icon-wrap">
      <view class="privacy-icon-shield">
        <text class="privacy-icon-mark">&#x25C9;</text>
      </view>
    </view>

    <!-- 标题与说明 -->
    <text class="privacy-title">欢迎来到住好房</text>
    <text class="privacy-desc">为了更好地保障您的权益，使用前请阅读并同意以下协议</text>

    <!-- 协议勾选区 -->
    <view class="privacy-check-row" bindtap="onTogglePrivacy">
      <view class="privacy-checkbox {{privacyChecked ? 'checked' : ''}}">
        <text wx:if="{{privacyChecked}}" class="privacy-check-mark">&#x2713;</text>
      </view>
      <view class="privacy-check-text">
        <text>我已阅读并同意</text>
        <text class="privacy-link" catchtap="onOpenAgreement">《用户协议》</text>
        <text>和</text>
        <text class="privacy-link" catchtap="onOpenPrivacy">《隐私政策》</text>
      </view>
    </view>

    <!-- 同意按钮 -->
    <view class="privacy-agree-btn {{privacyChecked ? '' : 'disabled'}}" bindtap="onAgreePrivacy">
      <text class="privacy-agree-text">同意并继续</text>
    </view>

    <!-- 退出 -->
    <view class="privacy-exit" bindtap="onDisagreePrivacy">
      <text class="privacy-exit-text">暂不同意，退出应用</text>
    </view>

    <!-- 安全区 -->
    <view class="privacy-safe"></view>
  </view>
</view>
