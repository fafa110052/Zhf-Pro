/**
 * 首页样式
 */

.page {
  background: #f8fafc;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ═══ 搜索栏 ═══ */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.search-box {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f1f5f9;
  border-radius: 36rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  opacity: 0.5;
}

.search-placeholder {
  font-size: 28rpx;
  color: #94a3b8;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #0f172a;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

/* ═══ Banner ═══ */
.banner-section {
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.banner-empty {
  margin: 20rpx 24rpx;
  padding: 80rpx 0;
  background: linear-gradient(135deg, #1e293b, #334155);
  border-radius: 16rpx;
  text-align: center;
}

.banner-empty-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

/* ═══ 分类快捷入口 ═══ */
.quick-section {
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}

.quick-list {
  display: flex;
  justify-content: space-around;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  background: #eff6ff;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-icon {
  font-size: 44rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

/* ═══ 通用区块 ═══ */
.section {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.section-more {
  font-size: 26rpx;
  color: #3b82f6;
}

.section-loading {
  padding: 40rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
}

.section-error {
  padding: 40rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.section-error .error-icon {
  font-size: 48rpx;
}

.section-error .error-text {
  font-size: 26rpx;
  color: #94a3b8;
}

/* ═══ 热门瀑布流 ═══ */
.hot-grid {
  display: flex;
  gap: 16rpx;
}

.hot-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hot-item {
  width: 100%;
}

/* ═══ 安全区 ═══ */
.safe-bottom {
  height: 24rpx;
}
