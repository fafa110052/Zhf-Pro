/**
 * 首页样式 V3.0 — 温暖精致风
 */

.page {
  background: var(--bg-page);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ═══ Banner ═══ */
.banner-section {
  margin: 20rpx 24rpx;
}

.banner-empty {
  margin: 20rpx 24rpx;
  padding: 100rpx 0;
  background: linear-gradient(135deg, #3d3226, #5a4a3a);
  border-radius: 20rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.banner-empty-icon {
  font-size: 64rpx;
}

.banner-empty-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.banner-empty-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ═══ 免费量房（步骤流程） ═══ */
.trust-section {
  position: relative;
  overflow: hidden;
}

.trust-section::before {
  content: '';
  position: absolute;
  top: 0;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(200, 169, 110, 0.06) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.trust-steps {
  display: flex;
  justify-content: space-between;
  position: relative;
  padding: 8rpx 0 0;
}

/* 连接线：横贯3个序号圆心的细线 */
.trust-steps::before {
  content: '';
  position: absolute;
  top: 20rpx;
  left: 40rpx;
  right: 40rpx;
  height: 2rpx;
  background: linear-gradient(90deg,
    rgba(200, 169, 110, 0.12),
    rgba(200, 169, 110, 0.35) 30%,
    rgba(200, 169, 110, 0.35) 70%,
    rgba(200, 169, 110, 0.12)
  );
  z-index: 0;
}

.trust-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  position: relative;
  z-index: 1;
}

.step-num-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 2;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: var(--color-accent);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(200, 169, 110, 0.25);
}

.step-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #fdf8f0, #f8f0e2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.step-icon {
  font-size: 40rpx;
}

.step-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  white-space: nowrap;
}

.step-desc {
  font-size: 20rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
}

/* ═══ 为什么选择住好房（2×2 图文网格） ═══ */
.adv-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.adv-card {
  width: calc(50% - 10rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx 28rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(180deg, #fefbf6, #fdf8f0);
  border-radius: var(--border-radius-lg);
  border: 1rpx solid rgba(200, 169, 110, 0.08);
  box-sizing: border-box;
}

.adv-card:nth-last-child(-n+2) {
  margin-bottom: 0;
}

.adv-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #fdf8f0, #f5efe0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.adv-icon {
  font-size: 48rpx;
}

.adv-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.adv-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.4;
}

/* ═══ 通用区块 ═══ */
.section {
  margin: 0 24rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-xl);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 0;
  width: 32rpx;
  height: 6rpx;
  background: var(--color-accent);
  border-radius: 3rpx;
  opacity: 0.6;
}

.section-more {
  font-size: 26rpx;
  color: var(--color-accent);
}

.section-loading {
  padding: 40rpx 0;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 26rpx;
}

.section-error {
  padding: 40rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.section-error .error-icon {
  font-size: 48rpx;
}

.section-error .error-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ═══ 热门瀑布流 ═══ */
.hot-grid {
  display: flex;
  gap: 16rpx;
}

.hot-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hot-item {
  width: 100%;
}

/* ═══ 设计团队 ═══ */
.team-scroll {
  width: 100%;
  white-space: nowrap;
}

.team-list {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}

.team-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 180rpx;
  padding: 24rpx 16rpx;
  background: #fefbf6;
  border-radius: var(--border-radius-lg);
  flex-shrink: 0;
}

.team-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  background: #f0ebe0;
}

.team-avatar {
  width: 100%;
  height: 100%;
}

.team-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.team-tag {
  font-size: 20rpx;
  color: var(--color-accent);
  background: var(--color-accent-light);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.team-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border-color);
  gap: 16rpx;
}

.team-stat {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.team-stat-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-accent);
}

.team-stat-dot {
  color: var(--border-color);
  font-size: 24rpx;
}

/* ═══ 免费量房按钮 ═══ */
.measure-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin-top: 20rpx;
  background: var(--gradient-warm);
  border-radius: 44rpx;
  box-shadow: 0 4rpx 16rpx rgba(200, 169, 110, 0.3);
}

.measure-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.measure-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

/* ═══ 安全区 ═══ */
.safe-bottom {
  height: 24rpx;
}

/* ═══════════════════════════════════════════
   隐私协议弹窗 — 居中模态框（overlay+modal 兄弟节点）
   ═══════════════════════════════════════════ */

/* 容器 */
.privacy-wrapper {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
  box-sizing: border-box;
}

/* 遮罩层 — 独立，只拦截背景点击 */
.privacy-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 0;
  animation: privacyFadeIn 240ms ease-out;
}

@keyframes privacyFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 居中模态卡片 — 独立层级 */
.privacy-modal {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 640rpx;
  background: var(--bg-card);
  border-radius: var(--border-radius-xl);
  padding: 48rpx 40rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: privacyScaleIn 280ms cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: var(--shadow-lg);
  pointer-events: auto;
}

@keyframes privacyScaleIn {
  from {
    opacity: 0;
    transform: scale(0.88) translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* ═══ 图标 — 纯 CSS 几何，零 Unicode ═══ */
.privacy-icon-wrap {
  margin-bottom: 28rpx;
}

.privacy-icon-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #fdf8f0, #f5efe0);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* 盾形主体 */
.privacy-icon-shield {
  width: 36rpx;
  height: 44rpx;
  background: var(--color-accent);
  border-radius: 8rpx 8rpx 12rpx 12rpx;
  position: relative;
}

/* 盾上圆点 */
.privacy-icon-dot {
  width: 12rpx;
  height: 12rpx;
  background: #fff;
  border-radius: 6rpx;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -60%);
}

/* ═══ 标题 ═══ */
.privacy-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  text-align: center;
}

/* ═══ 协议文案 — 内联富文本 ═══ */
.privacy-body {
  width: 100%;
  margin-bottom: 28rpx;
}

.privacy-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.privacy-link {
  font-size: 28rpx;
  color: var(--color-accent);
  font-weight: 500;
  line-height: 2;
  padding: 16rpx 6rpx;
  display: inline-block;
  min-height: 44rpx;
}

.privacy-link:active {
  opacity: 0.7;
}

/* ═══ 同意按钮 ═══ */
.privacy-agree-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gradient-warm);
  border-radius: 44rpx;
  transition: opacity 0.15s ease;
}

.privacy-agree-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.privacy-agree-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 2rpx;
}

/* ═══ 退出链接 ═══ */
.privacy-exit {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 24rpx;
}

.privacy-exit-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}
