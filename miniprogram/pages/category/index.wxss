/**
 * 分类筛选页样式 V2.0 — 温暖精致风
 */

/* ═══ 页面容器 ═══ */
.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: var(--bg-page);
}

/* ═══ 维度 Tab 栏 ═══ */
.tab-bar {
  display: flex;
  background: var(--bg-card);
  border-bottom: 2rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 18rpx;
  position: relative;
}

.tab-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
  transition: color 0.2s;
}

.tab-active .tab-text {
  color: var(--text-primary);
  font-weight: 700;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: var(--color-accent);
  border-radius: 3rpx;
}

/* ═══ 搜索关键词提示栏 ═══ */
.keyword-bar {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  background: var(--color-accent-light);
  border-bottom: 2rpx solid var(--border-color);
  gap: 10rpx;
}

.keyword-icon {
  font-size: 26rpx;
}

.keyword-text {
  font-size: 26rpx;
  color: var(--color-accent-deep);
  font-weight: 500;
  flex: 1;
}

.keyword-count {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.keyword-clear {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #f5f0e8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--color-accent);
}

/* ═══ 标签云区域 ═══ */
.tag-section {
  background: var(--bg-card);
  border-bottom: 2rpx solid var(--border-color);
}

.tag-cloud-wrap {
  max-height: 200rpx;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 16rpx 20rpx;
}

.tag-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #f5f0e8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}

.tag-chip:active {
  background: var(--border-color);
}

.tag-chip-active {
  background: var(--color-accent-light);
  color: var(--color-accent);
  border-color: var(--color-accent);
  font-weight: 500;
}

.tag-empty {
  padding: 32rpx;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 26rpx;
}

/* ═══ 已选筛选条 ═══ */
.filter-bar {
  background: var(--bg-card);
  padding: 12rpx 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-chips {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: var(--color-accent-light);
  border: 2rpx solid var(--border-color);
  border-radius: 6rpx;
  font-size: 24rpx;
}

.filter-chip-label {
  color: var(--text-secondary);
}

.filter-chip-name {
  color: var(--color-accent);
  font-weight: 500;
}

.filter-chip-close {
  color: var(--text-tertiary);
  font-size: 22rpx;
  margin-left: 2rpx;
}

.filter-clear {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: var(--color-danger);
  flex-shrink: 0;
}

/* ═══ 排序栏 ═══ */
.sort-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: var(--bg-card);
  border-bottom: 2rpx solid var(--border-color);
}

.sort-count {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.sort-right {
  display: flex;
  gap: 24rpx;
}

.sort-item {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 6rpx 0;
  position: relative;
}

.sort-active {
  color: var(--color-accent);
  font-weight: 600;
}

/* ═══ 节点回收提示 ═══ */
.trimmed-notice {
  display: flex;
  justify-content: center;
  padding: 16rpx 24rpx;
  margin-bottom: 12rpx;
  background: #fdf8ec;
  border-radius: 8rpx;
  border: 2rpx solid #f0e0b0;
}

.trimmed-notice text {
  font-size: 22rpx;
  color: #b8952a;
}

/* ═══ 瀑布流 ═══ */
.works-area {
  flex: 1;
  padding: 16rpx 16rpx 0;
}

.waterfall-grid {
  display: flex;
  gap: 16rpx;
}

.waterfall-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.waterfall-col:first-child {
  margin-right: 0;
}

.waterfall-item {
  width: 100%;
}

/* ═══ 首次加载 ═══ */
.loading-first {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ═══ 错误状态 ═══ */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 12rpx;
}

.error-icon {
  font-size: 72rpx;
}

.error-msg {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.error-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
}
