# ═══════════════════════════════════════
# 住好房 — 环境变量配置
# ═══════════════════════════════════════
# 复制此文件为 .env 并修改配置
#   cp .env.example .env
# ═══════════════════════════════════════

# 服务器端口
PORT=3000

# JWT 密钥（生产环境请更换为复杂随机字符串）
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=zhuhaofang-dev-secret-key-2026

# 微信小程序配置
WECHAT_APPID=wx45a2339808c171aa
WECHAT_SECRET=bc55d399de44a603f3b815132c5d3cb0
# 开发模式：无 AppID 时使用手机号登录（生成 mock openid）
# 正式上线后设为 false
WECHAT_DEV_MODE=true

# 微信商户（支付相关，MVP 阶段暂不需要）
# WECHAT_MCHID=
# WECHAT_PAY_KEY=

# ═══════════════════════════════════════
# 生产环境建议
# ═══════════════════════════════════════
# 1. JWT_SECRET: 使用随机生成的 64 位十六进制字符串
# 2. WECHAT_APPID/SECRET: 从小程序后台获取
# 3. 上线后将 WECHAT_DEV_MODE 设为 false
